        function closeOnboarding() {
            $('#onboarding-popup').remove();
            document.location.hash = '';
        }



        var tData = `<%=GetMemberDetailsByMemberIDResponse.JsonResult%>`;
        //console.log(cmemberData);
        var jtData = JSON.parse(cmemberData)[0];
        var jmemberData = JSON.parse(cmemberData)[0];
