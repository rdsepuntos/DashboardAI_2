        var __menuData = [];
        var _isValidJson = true;
        $(document).ready(function () {
		setTimeout(function() {		hashhelp();},500)
		hashhelp();
   <%--          $.ajax({
                type: "POST",
                url: `<%=GetMenus()%>`,
                async: true,
            }).done(function (data) {--%>
            //console.log(data);        
            var menuData = []
            try {
                menuData =  <%=TreeView %>;
                __menuData = menuData;
            } catch (e) {
                _isValidJson = false;
            }

            //$.each(menuData.Menus.Menu, function (i, e) {
            //    console.log(e.Menu)
            //    $.each(e.Menu, function (ii, men) {
            //        console.log(men)
            //        if (men && men.PageID === '669') {
            //            menu.PageCaption = `${menu.PageCaption} (Legacy)`;
            //            alert(menu.PageCaption)
            //        }
            //    })

            //})

            function setPageLink(menu, isHeader) {

                if (menu.PageID === '669'
                    || menu.PageID === '800'
                    || menu.PageID === '814'
                    || menu.PageID === '817'
                    || menu.PageID === '785'
                    || menu.PageID === '719'
                    || menu.PageID === '677'
                    || menu.PageID === '720'
                    || menu.PageID === '811'
                    //|| menu.PageID === '744'
                ) {
                    menu.PageCaption = `${menu.PageCaption} (Legacy)`;
                }
              
                if (menu.PageCaption.indexOf('V2') > -1) {
                    menu.PageCaption = menu.PageCaption.replace('V2','')
                }

                if (menu.PageCaption.indexOf('v2') > -1) {
                    menu.PageCaption = menu.PageCaption.replace('v2', '')
                }

                var pageLink = '';
                if (menu.PageID === '5769') {
                    pageLink = 'href="#initonboard"';
                }
                else if (isHeader && menu.PageID !== '1009' && (!menu.PageLink || menu.PageLink === '#'))
                    pageLink = 'heref="javascript:void(0)"'
                else if (menu.IsPanel === 'true' && (menu.IsPanelStatic === 'true' || menu.IsPanelDynamic === 'true')) {
                    pageLink = 'href="' + menu.PanelUrl + '"';
                } else if (menu.PageLink !== '#') {
                    if (menu.PageLink.indexOf('Page=') > -1) {
                        pageLink = 'href="' + menu.PageLink + '"';
                    }
                    else
                        pageLink = 'href="' + menu.PageLink + ((menu.PageLink.indexOf('?') > 0 ? '&Page=' : '?Page=')) + menu.PageID + '"';
                }
                return pageLink;


            }

            // createSidebarSubMenu & setSidebarSubMenu functions are used to get the sidebar sub menus

            function createSidebarSubMenu(menu, icon, cssClass, isHeader) {
                var addClass = '';
                if (isHeader && menu.PageID !== '1009') {
                    addClass = 'header-link'
                }
                var navbarLeftChild = '';
                navbarLeftChild = `<li class="nav-item ${addClass}">`;
                navbarLeftChild += '<a  parent="' + menu.LinkParentPageID + '" id="apage-' + menu.PageID + '"' + setPageLink(menu, isHeader) + ' class="px-2">';
                navbarLeftChild += icon;
                navbarLeftChild += '<span class="item-name ' + cssClass + '">' + menu.PageCaption + '</span>';
                navbarLeftChild += '</a>';
                navbarLeftChild += '</li>';
                return navbarLeftChild;
            }

            function setSidebarSubMenu(subMenu, dataItemName, headerText) {
                var navbarLeftChild = '';
                navbarLeftChild += '<ul class="childNav" data-parent="' + dataItemName + '">';
                if (__primaryColor.SwitchMenu) {
                    navbarLeftChild += `<li class="p-2 hide-lg bg-f2f3f5"><div class="d-flex justify-content-between">
					<div>
					<a href="javascript:closeSubMenu()">
					<span style="font-size: 14px; position:relative; top: 1px;" class="linear-chevron-left"></span>
					</a>
					<span class="font-weight-bold">
					${headerText}
					</span>
					</div><div>
					<a href="javascript:closeSubMenu()">
					<span style="font-size: 1rem" class="linear-cross"></span>
					</a>
					</div>
				</div>
				</li>`
                }
                $(subMenu).each(function (index, menu) {

                    if (menu.Menu && menu.Menu.length > 0)
                        navbarLeftChild += createSidebarSubMenu(menu, '<i class="nav-icon ' + menu.PageIcon + ' pr-1"></i>', 'text-13 font-weight-bold', true);
                    else
                        navbarLeftChild += createSidebarSubMenu(menu, '<i class="nav-icon ' + menu.PageIcon + ' pr-1"></i>', 'text-13 font-weight-bold', true);

                    if (menu.Menu) {
                        $(menu.Menu).each(function (index, menuSub1) {
                            if (__primaryColor.SwitchMenu) {
                                menuSub1.PageCaption = menuSub1.PageCaption.replace("Manager", "")
                                menuSub1.PageCaption = menuSub1.PageCaption.replace("Equipment", "")
                                menuSub1.PageCaption = menuSub1.PageCaption.replace("Setup ", "")
                                menuSub1.PageCaption = menuSub1.PageCaption.replace("Emergency Washing Facilities", "Emergency Wash")
                                menuSub1.PageCaption = menuSub1.PageCaption.replace("Legislation, Standards and Codes of Practice", "Regulations & Standards")
                                menuSub1.PageCaption = menuSub1.PageCaption.replace("Meetings, Consultations and Complaints", "Meetings & Consultation")
                            }
                            icon = menuSub1.PageIcon === '' || menuSub1.PageIcon === null ? 'iconsmind-Arrow-Out-Right' : menuSub1.PageIcon;

                            //navbarLeftChild += createSidebarSubMenu(menuSub1, '<i class="pl-2 nav-icon ' + icon + ' pr-1"></i>', '');

                            navbarLeftChild += createSidebarSubMenu(menuSub1, '<span style="    padding-left: 21px !important;"></span>', 'pl-2');
                            if (menuSub1.Menu) {
                                $(menuSub1.Menu).each(function (index, menuSub2) {
                                    icon = menuSub2.PageIcon === '' || menuSub2.PageIcon === null ? 'iconsmind-Arrow-Out-Right' : menuSub2.PageIcon;

                                    // navbarLeftChild += createSidebarSubMenu(menuSub2, '<i class="nav-icon ' + icon + ' pl-3"></i>', '');
                                    navbarLeftChild += createSidebarSubMenu(menuSub2, '<span style="    padding-left: 21px !important;"></span>', 'pl-2');
                                });
                            }
                        });
                    }
                });

                navbarLeftChild += '</ul>';

                //if(!__primaryColor.SwitchMenu)
                $('#navbar-left-child').append(navbarLeftChild);

                if (__primaryColor.SwitchMenu) {
                    setTimeout(function () {

                        $(`[data-item="${dataItemName}"]`).append(`
                        <div id="sub-${dataItemName}" class="dropdown-menu dropdown-menu-right">
                               ${navbarLeftChild}
                        </div>
                    `);
                        $(`[data-item="${dataItemName}"]`).addClass('dropdown')
                        //$(`[data-item="${dataItemName}"]`).attr('data-toggle', 'dropdown')
                        $(`[data-item="${dataItemName}"]`).attr('data-target', `#sub-${dataItemName}`)
                        $(`[data-item="${dataItemName}"]`).attr('aria-haspopup', 'true')
                        $(`.dropdown-menu .nav-item`).removeClass('nav-item')
                        $(`.dropdown-menu ul`).attr('style', 'list-style-type:none; width:330px; padding:0px;')
                        $(`.dropdown-menu ul a`).addClass('text-dark py-2')
                        $(`.dropdown-menu ul li`).addClass('py-1')
                        //` data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"`
                        $('.nav-item-hold').addClass('d-flex');
                        $('.nav-text').addClass('d-block w-100')
                        $('.nav-item-hold .linear-chevron-right').remove()
                        $('.nav-item-hold').append(`<i style="font-size: 14px !important; position:relative; top: 2px;" 
                                    class="nav-icon linear-chevron-right "></i>`)


                        $(document).ready(function () {

                            $('.nav-item .dropdown-menu').each(function (i, e) {
                                var height = $(e).height();
                                var top = $(e).parent().offset().top;
                                console.log({
                                    height: height,
                                    top: top
                                })

                                if (top > 400 && height > 400) {
                                    var ctrTop = (height - top)
                                    if (ctrTop > 0) {
                                        ctrTop = -250
                                    } else {
                                        ctrTop = -250
                                    }
                                    $(e).attr('style', `top: ${ctrTop}px !important; position:absolute !important;`)
                                    console.log($(e))
                                }
                            })

                        })

                    }, 1000)
                }


            }

            // createTopRightSubMenu & setTopRightSubMenu functions are used to get the top right menus

            function createTopRightSubMenu(menu, bsPadding, icon, cssClass) {
                return '<a id="pageid-' + menu.PageID + '" name="' + menu.PageCaption + '" class="dropdown-item ' + bsPadding + '" ' + setPageLink(menu) + '">' +
                    icon + ' ' +
                    '<span class="' + cssClass + '">' + menu.PageCaption + '</span>' +
                    '</a>';
            }

            function setTopRightSubMenu(subMenu) {
                var topRightMenuChild = '';
                $(subMenu).each(function (index, menu) {
                    icon = menu.PageIcon;
                    topRightMenuChild += createTopRightSubMenu(menu, 'px-3', '<i style="font-size:20px; position:relative; top:4px;" class="nav-icon ' + icon + ' pr-1"></i>', 'header-link');

                    if (menu.Menu) {
                        $(menu.Menu).each(function (index, menuSub1) {
                            icon = menuSub1.PageIcon === '' || menuSub1.PageIcon === null ? 'iconsmind-Arrow-Out-Right' : menuSub1.PageIcon;

                            topRightMenuChild += createTopRightSubMenu(menuSub1, 'px-3', '<i style="padding-left:28px;"></i>', '');

                            if (menuSub1.Menu) {
                                $(menuSub1.Menu).each(function (index, menuSub2) {
                                    topRightMenuChild += createTopRightSubMenu(menuSub2, '', '', 'pl-3');
                                });
                            }
                        });
                    }
                });
                return topRightMenuChild;
            }

