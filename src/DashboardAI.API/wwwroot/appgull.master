<body class="text-left">


    <style>
        .layout-sidebar-large .sidebar-left {
            left: calc(-120px - 35px);
            z-index: 90;
            transition: all .24s ease-in-out;
        }

        /* ===== Header Search Styles ===== */
        .header-search-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .header-search-wrapper .aa-Autocomplete, #header-autocomplete {
            width: 100%;
        }

        .header-search-wrapper .aa-Form {
            border-radius: 20px;
            border: none;
            background: rgba(255,255,255,0.15);
            box-shadow: none;
            transition: background 0.3s;
            display:block !important
        }

        .header-search-wrapper .aa-Form:focus-within {
            background: rgba(255,255,255,0.25);
        }

        .header-search-wrapper .aa-InputWrapperPrefix,
        .header-search-wrapper .aa-InputWrapperSuffix,
        .header-search-wrapper .aa-Label,
        .header-search-wrapper .aa-ClearButton,
        .header-search-wrapper .aa-SubmitButton,
        .header-search-wrapper .aa-LoadingIndicator {
            display: none;
        }

        .header-search-wrapper .aa-Input {
            border-radius: 5px;
            border: none;
            padding: 8px 44px 8px 40px !important;
            font-size: 14px;
            width: 100%;
            background: transparent;
            color: #222;
            border: 1px solid #ced4da !important;
        }

     

        .header-search-wrapper .aa-Input:focus {
            outline: none;
        }

        .header-search-btn {
            position: absolute;
            right: 8px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: rgba(255,255,255,0.8);
            font-size: 16px;
            padding: 4px;
            cursor: pointer;
            z-index: 1;
        }

        .header-search-btn:hover {
            color: #fff;
        }

        .header-search-icon-left {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #6c757d;
            font-size: 18px;
            pointer-events: none;
            z-index: 1;
        }

            .aa-Panel  {
                z-index: 9999999!important;
            }
        .header-search-wrapper .aa-Panel {
            max-height: 440px;
            overflow-y: auto;
            border-radius: 8px;
            border: 1px solid #d0d7de;
            box-shadow: 0 4px 16px rgba(27, 31, 36, 0.2);
            background: white;
            margin-top: 4px;
            padding: 0;
            position: absolute;
            left: 0;
            right: 0;
            z-index: 9999999!important;
        }

        .header-search-wrapper .aa-Panel::-webkit-scrollbar { width: 6px; }
        .header-search-wrapper .aa-Panel::-webkit-scrollbar-thumb { background: #dadce0; border-radius: 4px; }

        .header-search-wrapper .aa-List { list-style: none; padding: 8px 0; margin: 0; }
        .header-search-wrapper .aa-Item { padding: 0; margin: 0; }
        .header-search-wrapper .aa-ItemContent { padding: 0; }

        .header-suggestion-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 16px;
            border-bottom: 1px solid #e1e4e8;
            cursor: pointer;
            transition: background 0.15s;
        }

        .header-suggestion-item:last-child { border-bottom: none; }

        .header-search-wrapper .aa-Item[aria-selected="true"] .header-suggestion-item,
        .header-suggestion-item:hover {
            background: #f6f8fa;
        }

        .header-suggestion-icon {
            width: 34px;
            height: 34px;
            border-radius: 6px;
            background: #ddf4ff;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0969da;
            font-size: 15px;
            flex-shrink: 0;
        }

        .header-suggestion-content { flex: 1; min-width: 0; }

        .header-suggestion-title {
            font-size: 13px;
            font-weight: 600;
            color: #24292f;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            margin-bottom: 2px;
        }

        .header-suggestion-meta {
            font-size: 11px;
            color: #57606a;
            display: flex;
            align-items: center;
            gap: 5px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .header-suggestion-meta .result-id { color: #0969da; font-weight: 600; }
        .header-suggestion-meta .result-status {
            padding: 0 6px;
            border-radius: 2em;
            font-size: 11px;
            font-weight: 500;
            line-height: 16px;
        }
        .header-suggestion-meta .status-draft { background: #fef2c0; color: #7d4e00; }
        .header-suggestion-meta .status-completed { background: #dafbe1; color: #0f6027; }
        .header-suggestion-meta .sep { color: #d0d7de; }

        .header-suggestion-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: #3B98F1;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 12px;
            flex-shrink: 0;
            text-transform: uppercase;
            margin-left: auto;
        }
        /* Search Results Modal */
        .aa-view-all-footer {
            padding: 10px 16px; text-align: center; font-size: 13px;
            color: #0969da; cursor: pointer;
            border-top: 1px solid #e1e4e8; background: #f6f8fa;
        }
        .aa-view-all-footer:hover { background: #eaeef2; text-decoration: underline; }
        .search-modal-item {
            display: flex; align-items: center; padding: 12px 16px;
            border-bottom: 1px solid #e1e4e8; cursor: pointer;
            text-decoration: none !important; color: inherit !important;
        }
        .search-modal-item:hover { background: #f6f8fa; }
        .smi-icon {
            width: 34px; height: 34px; border-radius: 6px;
            background: #ddf4ff; display: flex; align-items: center;
            justify-content: center; color: #0969da; font-size: 15px;
            flex-shrink: 0; margin-right: 12px;
        }
        .smi-content { flex: 1; min-width: 0; }
        .smi-title { font-size: 14px; font-weight: 600; color: #24292f; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 2px; }
        .smi-meta { font-size: 11px; color: #57606a; display: flex; align-items: center; gap: 5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .smi-id { color: #0969da; font-weight: 600; }
        .smi-sep { color: #d0d7de; }
        .smi-status { padding: 0 6px; border-radius: 2em; font-size: 11px; font-weight: 500; line-height: 16px; }
        .smi-status.status-draft { background: #fef2c0; color: #7d4e00; }
        .smi-status.status-completed { background: #dafbe1; color: #0f6027; }
        .smi-avatar {
            width: 30px; height: 30px; border-radius: 50%; background: #3B98F1;
            display: flex; align-items: center; justify-content: center;
            color: white; font-weight: 600; font-size: 11px; flex-shrink: 0; margin-left: 12px;
        }
        /* ===== End Header Search Styles ===== */

        #ctl00_wcFeedbackCommentTb_wrapper {
            border: 1px solid #dee2e6;
            border-radius: .25rem !important;
        }

        #ctl00_SrvQTB_wrapper, #ctl00_DifUTB_wrapper, #ctl00_NotLTB_wrapper, #ctl00_TExpTB_wrapper, #ctl00_OthrTB_wrapper {
            border: 1px solid #dee2e6;
            border-radius: .25rem !important;
            width: 75% !important;
        }

        #ctl00_wcFeedbackCommentTb, #ctl00_SrvQTB, #ctl00_DifUTB, #ctl00_NotLTB, #ctl00_TExpTB, #ctl00_OthrTB {
            padding: 5px;
        }

        .center-page {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 70vh
        }
    </style>

    <!-- Google Tag Manager (noscript) -->
    <noscript>
        <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T79B63X"
            height="0" width="0" style="display: none; visibility: hidden"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->

