        var __accessUser = [];
        function switchSkip() {
            return jQuery.ajax({
                type: "POST",
                url: "../../NetServices/PostDynamicChecklist.asmx/spSkipOnboarding",
                data: JSON.stringify({
                    data: {
                        PermanentlyhRemoveOnboarding: false
                    }
                }),
                dataType: "JSON",
                contentType: 'application/json'
            }).done(function (next) {
                $('#onboarding-popup').remove();
            });

        }
        function allowUpgradeAccess() {
            return jQuery.ajax({
                type: "POST",
                url: "../../NetServices/PostDynamicChecklist.asmx/spGenerateTableJSONv2",
                data: JSON.stringify({
                    data: {
                        TableName: ' vw_membersWithStore  ',
                        Condition: ` UserName = '${jmemberData.UserName}'  `,
                        Fields: ` UserName `,
                        Limit: 509,
                        OrderBy: '1 desc',
                        CurPage: 1,
                        IsDistinct: true
                    }
                }),
                dataType: "JSON",
                contentType: 'application/json'
            }).done(function (store) {
                try {
                    __accessUser = JSON.parse(store.d.JsonValue);
                } catch (e) { }
            });
        }

        allowUpgradeAccess().done(function () {
            if (jmemberData.HasStore)
                if ($('#upgrade').length === 0 && __accessUser && __accessUser.length > 0 && jmemberData.ZohoUserName !== '' && jmemberData.StoreID === __appGullStoreId)
                    if (jmemberData.IsDemo)
                        $('[href="../../App/Admin/ManageSubscriptionInfo.aspx"]').after(`<a id="upgrade" class="pl-3 dropdown-item" href="../../App/Tools/Upgrade2.aspx">License Upgrade</a>`);
                    else
                        $('[href="../../App/Admin/ManageSubscriptionInfo.aspx"]').after(`<a id="upgrade" class="pl-3 dropdown-item" href="../../App/Tools/Upgrade.aspx">License Upgrade</a>`);

        });


        Sys.Application.add_load(SetCustomCheckbox);
        var _disableMenu = '<%=DisableMenu%>';

        if (_disableMenu === "True") {
            $('body').append(`<style>#breadcrumbs {display: none !important}</style>`);
            $('.menu-toggle').click();
            $('.menu-toggle').remove()
            $('.navigation-left').remove();
            $('.main-content-wrap').removeClass('sidenav-open');
            $('.logo-buttons').remove();
            $('.main-header .header-part-right').remove()
            $('.app-admin-wrap .col-md-5').html(`<h4 style="margin-top:20px" class="text-right mr-3">${jtData.StoreName}</h4>`);
            $('#ctl00_wcMainContentPlaceHolder_wcPageView5029_userControl_action_frommasterlist').remove()
            setTimeout(function () {
                $('#ctl00_wcMainContentPlaceHolder_wcPageView5029_userControl_action_frommasterlist').remove()
            }, 100)
            setTimeout(function () {
                $('#ctl00_wcMainContentPlaceHolder_wcPageView5029_userControl_action_frommasterlist').remove()
            }, 300)
            setTimeout(function () {
                $('#ctl00_wcMainContentPlaceHolder_wcPageView5029_userControl_action_frommasterlist').remove()
            }, 500)
            setTimeout(function () {
                $('#ctl00_wcMainContentPlaceHolder_wcPageView5029_userControl_action_frommasterlist').remove()
            }, 1000)
        }
    </script>


    <asp:Panel runat="server" ID="zcgascript" Visible="false">
        <script type="text/javascript">
            window.AppcuesSettings = {
                enableURLDetection: true
            };

        </script>
        <script src="//fast.appcues.com/142083.js"></script>


       <script type="text/javascript">

           var cmemberData = `<%=GetMemberDetailsByMemberIDResponse.JsonResult%>`;
           //console.log(cmemberData);
           var jmemberData = JSON.parse(cmemberData)[0];
           //console.log(jmemberData)

           function changeAppCues(url, type) {

               if (!jmemberData.HasStore && type === 'whs-risks') {
                   url = 'https://app.whsmonitor.com.au/App/Dashboard/Dashboard.aspx?Page=983&appcue=a6c57268-be71-4b10-8d10-4d8006b195f3'
               }

               $('#apcwhs-frame').remove();
               $('body').append(`<div id="apcwhs-frame" class="d-none"><iframe src="${url}" /> </div>`);
               appcueswhsrule();
               setTimeout(function () {
                   if ($('appcues-checklists').length === 0) {
                       appcueswhsrule()
                   }
               }, 2000)
               setTimeout(function () {
                   if ($('appcues-checklists').length === 0) {
                       appcueswhsrule()
                   }
               }, 3000)
               setTimeout(function () {
                   if ($('appcues-checklists').length === 0) {
                       appcueswhsrule()
                   }
               }, 3500)
               setTimeout(function () {
                   if ($('appcues-checklists').length === 0) {
                       appcueswhsrule()
                   }
               }, 4000)
               setTimeout(function () {
                   if ($('appcues-checklists').length === 0) {
                       appcueswhsrule()
                   }
               }, 4500)
               setTimeout(function () {
                   if ($('appcues-checklists').length === 0) {
                       appcueswhsrule()
                   }
               }, 5000)

               return jQuery.ajax({
                   type: "POST",
                   url: "../../NetServices/PostDynamicChecklist.asmx/spUpdateStoreSetup",
                   data: JSON.stringify({
                       data: {
                           TertiaryColor: type
                       }
                   })
                   ,
                   dataType: "JSON",
                   contentType: "application/json",
                   processData: false
               }).done(function () {
                   jQuery.ajax({
                       type: "POST",
                       url: "../../NetServices/PostDynamicChecklist.asmx/spSkipOnboarding",
                       data: JSON.stringify({
                           data: {
                               PermanentlyhRemoveOnboarding: false
                           }
                       }),
                       dataType: "JSON",
                       contentType: 'application/json'
                   }).done(function (next) {
                       document.location.href = url;
                   });
               })

           }




           function whsGenAppCues() {

               if (jmemberData.AppcuesURL !== ''
                   && $('#appcues-whs-elem').length === 0) {
                   $('.sidebar-left > .navigation-left').prepend(`
				
				
			<li id="appcues-whs-elem" class="nav-item" style="background-color:#2d8eff!important;;"> <a style="padding-left: 16px !important; padding-top:.65rem!important; padding-bottom:.65rem!important" href="javascript:manualRightModal('#modal-tour')" class="pl-2 py-3 d-flex"><i class="nav-icon icon-arventa-start_an_audit pr-1" style="font-size:1.3REM; Color:#FFFF;"></i><span class="item-name  " style="color:#fff;margin-top: 0px;margin-left:7px">System Tour</span></a></li>
					
					
					`)
               }

           }

           const popupCenter = ({ url, title, w, h }) => {
               // Fixes dual-screen position                             Most browsers      Firefox
               const dualScreenLeft = window.screenLeft !== undefined ? window.screenLeft : window.screenX;
               const dualScreenTop = window.screenTop !== undefined ? window.screenTop : window.screenY;

               const width = window.innerWidth ? window.innerWidth : document.documentElement.clientWidth ? document.documentElement.clientWidth : screen.width;
               const height = window.innerHeight ? window.innerHeight : document.documentElement.clientHeight ? document.documentElement.clientHeight : screen.height;

               const systemZoom = width / window.screen.availWidth;
               const left = (width - w) / 2 / systemZoom + dualScreenLeft
               const top = (height - h) / 2 / systemZoom + dualScreenTop
               const newWindow = window.open(url, title,
                   `
      scrollbars=yes,
      width=${w / systemZoom}, 
      height=${h / systemZoom}, 
      top=${top}, 
      left=${left},
	  resizable=0
      `
               )

               if (window.focus) newWindow.focus();
           }


           Sys.Application.add_load(SetCustomCheckbox);

           function showMobileView() {
               popupCenter({
                   url: document.location.href, title: 'Mobile View', h: 815, w: 412
               })

           }

           function appcueswhsrule() {

               const timestampInSeconds = Math.floor(Date.now() / 1000);
               window.Appcues.identify(
                   jmemberData.UserName, // unique, required
                   {
                       // example custom user properties

                       createdAt: timestampInSeconds, // Unix timestamp of user signup date
                       role: jmemberData.Modules, // Current user’s role or permissions
                       firstName: jmemberData.FirstName, // current user's first name
                       email: jmemberData.Email, // Current user's email

                   }
               );
           }

           whsGenAppCues();
           if (jmemberData.IsDemo && __lstsa === '')
               switchAcoundFunction();
           function switchAcoundFunction() {
               jQuery.ajax({
                   type: "POST",
                   url: "../../NetServices/PostDynamicChecklist.asmx/spGenerateTableJSONv2",
                   data: JSON.stringify({
                       data: {
                           TableName: "Agtech_UserMgmt.dbo.vw_WorkerUsers",
                           Condition: ` ParentUserName = '${jmemberData.UserName}' or ChildUserName = '${jmemberData.UserName}'`,
                           Fields: 'ChildUserID, ChildUserName, ParentUserID, ParentUserName',
                           Limit: 500,
                           OrderBy: " 1 asc ",
                           CurPage: 1
                       }
                   }),
                   dataType: "JSON",
                   contentType: 'application/json'
               }).done(function (next) {
                   var jj = JSON.parse(next.d.JsonValue)[0];

                   if ($('body').width() >= 600) {
                       if (jj.ParentUserName !== jmemberData.UserName) {
                           $(`#btnSwitchAccount`).html(`
						
						<div class="btn-group mr-5">
						<button  style="border:0px !important;background-color:#2d8eff !important" class="shadow-none btn btn-info  border-0 " type="button" onclick="document.location.href='../../../cregister/lg.aspx?pc=${jj.ChildUserID}'"   type="button">User View</button>
						<button style="background-color: #e0e0e0 !important; color: #231f21 !important" class="shadow-none btn btn-light border-0 text-white" onclick="document.location.href='../../../cregister/lg.aspx?pc=${jj.ParentUserID}'" type="button">Admin View</button>
						
						</div>
						<button  style="color: #2d8eff!important;background-color:#fff !important ;border: 1px solid #2d8eff !important;" class="shadow-none border-0  btn btn-light text-dark" type="button" onclick="showMobileView()" type="button">Mobile View</button>
						
						`)

                       } else {
                           $(`#btnSwitchAccount`).html(`
						
						
						<div class="btn-group mr-5">
						<button  style="background-color: #e0e0e0 !important; color: #231f21 !important" class="shadow-none border-0  btn btn-light text-dark" type="button" onclick="document.location.href='../../../cregister/lg.aspx?pc=${jj.ChildUserID}'" type="button">User View</button>
						<button  onclick="document.location.href='../../../cregister/lg.aspx?pc=${jj.ParentUserID}'"  class="shadow-none border-0  btn btn-info text-white" style="border:0px !important;background-color:#2d8eff !important"   type="button">Admin View</button>
	
						</div>
						<button  style="color: #2d8eff!important;background-color:#fff !important ;border: 1px solid #2d8eff !important;" class="shadow-none border-0  btn btn-light text-dark" type="button" onclick="showMobileView()" type="button">Mobile View</button>
						
						`);
                       }


                   } else {
                       if (jj.ParentUserName !== jmemberData.UserName) {
                           $(`#btnSwitchAccount`).html(`
						
						<div class="btn-group">
						<button  style="border:0px !important;background-color:#2d8eff !important" class="shadow-none btn btn-info  border-0 " type="button" onclick="document.location.href='../../../cregister/lg.aspx?pc=${jj.ParentUserID}'"   type="button">User View</button>
						<button style="background-color: #e0e0e0 !important; color: #231f21 !important" class="shadow-none btn btn-light border-0 text-white" onclick="document.location.href='../../../cregister/lg.aspx?pc=${jj.ParentUserID}'" type="button">Admin View</button>
						
						</div>
						`)
                       } else {
                           $(`#btnSwitchAccount`).html(`
						
						
						<div class="btn-group">
						<button  style="background-color: #e0e0e0 !important; color: #231f21 !important" class="shadow-none border-0  btn btn-light text-dark" type="button" onclick="document.location.href='../../../cregister/lg.aspx?pc=${jj.ChildUserID}'" type="button">User View</button>
						<button  onclick="document.location.href='../../../cregister/lg.aspx?pc=${jj.ChildUserID}'"  class="shadow-none border-0  btn btn-info text-white" style="border:0px !important;background-color:#2d8eff !important"   type="button">Admin View</button>

						</div>
						`);
                       }

                   }


               });
           }


           if (__lstsa !== '' && !jmemberData.IsDemo) {
               if ($(`[script="../../assets/dashboard/kendo.all.min.js?ver=20250215"]`).length === 0) {
                   $('body').append(`<script src="../../assets/dashboard/kendo.all.min.js"><\/script>`)
               }
               console.log('adminadminadminadmin');
               //$('body').append(`<style>#onboarding-popup {display: none !important}</style>`)
               $(`#btnSwitchAccount`).html(`<div class="d-flex">
				<div style="width: 83px; color:#222; position: relative; top: 9px; left: 0px;">Switch User</div>
				<div>
				<input type="text" class="form-control"  id="switch-user"/>
				</div>
				</div>`)

               $(`#btnSwitchAccount`).attr('style', 'position: relative; top: 6px; width: 350px;')
               var ddlAudData = new kendo.data.HierarchicalDataSource({
                   serverFiltering: true,
                   transport: {
                       read: {
                           type: "POST",
                           url: "../../NetServices/POSTDynamicChecklist.asmx/GetAuditedLimit",
                           dataType: "JSON",
                           contentType: 'application/json'
                       },
                       parameterMap: function (sr, y) {
                           var search = '';
                           if (sr.filter && sr.filter.filters.length > 0) {
                               search = sr.filter.filters[0].value;
                           }
                           var pData = {
                               data: {
                                   StoreID: __appGullStoreId,
                                   LocType: 4,
                                   LocID: 0,
                                   MemberId: 0,
                                   Search: search,
                                   SearchID: -1000
                               }
                           }
                           return JSON.stringify(pData)
                       }
                   },
                   schema: {
                       data: function (resp) {
                           return resp.d.recordList;
                       },
                       model: {
                           id: 'IDNo',
                           hasChildren: 'test'
                       }
                   }
               });

               var memberId = '<%=Agtech.Web.UI.Utility.GetCurrentMemberID() %>';
               console.log('memberidmemberidmemberidmemberidmemberidmemberid');
               console.log(memberId)
               jQuery('#switch-user').kendoComboBox({
                   dataTextField: 'RowDescription',
                   dataValueField: 'IDNo',
                   dataSource: ddlAudData,
                   checkAll: false,
                   filter: "contains",
                   loadOnDemand: true,
                   serverFiltering: true,
                   value: memberId,
                   change: function (e) {

                       jQuery.ajax({
                           type: "POST",
                           url: "../../NetServices/PostDynamicChecklist.asmx/spGenerateTableJSONv2",
                           data: JSON.stringify({
                               data: {
                                   TableName: "StoreUserUserID",
                                   Condition: ` StoreID = ${__appGullStoreId} and MemberID = ${jQuery('#switch-user').data('kendoComboBox').value()} `,
                                   Fields: 'UserID, StoreUserID, StoreID',
                                   Limit: 500,
                                   OrderBy: " 1 asc ",
                                   CurPage: 1
                               }
                           }),
                           dataType: "JSON",
                           contentType: 'application/json'
                       }).done(function (next) {
                           var jj = JSON.parse(next.d.JsonValue)[0];

                           document.location.href = `../../cregister/lg.aspx?pc=${jj.UserID}`
                       });

                   },
                   dataBound: function (e) {

                       prinit = false;
                   }
               });

           }
        </script>


       
