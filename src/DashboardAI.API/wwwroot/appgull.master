    <script>

        if ($('body').width() < 768) {
            $(document).ready(function () {
                setTimeout(function () {
                    $('.menu-toggle').off();
                    $(document).on('click', '#mob-overlay', function () {

                        $('.open').fadeOut(0)
                        $('#navbar-left-child').removeClass('open')
                        setTimeout(function () { $('.open').removeClass('open'); }, 300)
                    });

                    $(document).on('click', '#navbar-left .nav-item', function () {

                    });
                    $(document).on('click', '.menu-toggle', function () {
                        $('.sidebar-left').fadeOut(0);
                        $('#navbar-left-child').fadeOut(0);

                        if ($('.sidebar-left').hasClass('open')) {
                            $('.sidebar-left').fadeOut(300);
                            $('.sidebar-left').removeClass('open');
                        } else {
                            $('.sidebar-left').fadeIn(300);
                            $('.sidebar-left').addClass('open');
                        }

                        //$('.sidebar-left').removeAttr('style');
                        setTimeout(function () {
                            $('.active').removeClass('active');
                            $('#navbar-left-child').removeClass('open');
                        }, 300)
                    })
                });
            }, 100)
        }

        var __appGullStoreId = <%=GetCurrentStoreID()%>;
        var __isCompany = '<%=IsSiteAccount %>';
        var __storeUserId = '<%=StoreUserID %>';
        var __lstsa = '<%=LoginType %>';


        var __logo ='<%=spGetStoreSetupFE.Logo%>'
        var __primaryColor = {};

        try {
            $(document).ready(function () {
                loadSetupTheme();
            })
            __primaryColor = JSON.parse('<%=spGetStoreSetupFE.PrimaryColor%>');
            var __secondaryColor = '<%=spGetStoreSetupFE.SecondaryColor%>';
            if (!__primaryColor.SwitchMenu) {
                $('body').append(`<style>
							
							[gridtype="dashboard-table"] .gridstack-body {
								overflow: auto !important
							}
							
							</style>`);
            }
        }


        catch (e) {

            $('body').append(`<style>
							
							[gridtype="dashboard-table"] .gridstack-body {
								overflow: auto !important
							}
							
							</style>`);
        }
        //__primaryColor.SwitchMenu = true;


        function closeSubMenu() {

            $('.sidebar-left-secondary').removeClass('open').attr('style', 'display: none !important')


        }
        function loadSetupTheme() {
            $('#custom-theme').remove();

            if (__primaryColor.SwitchMenu) {

                $('.nav-text.d-block').fadeOut();
                $('.main-content-wrap').hover(function () {
                    $('.nav-item.active').removeClass('active')
                    $('#navbar-left').addClass('slide-in');
                    $('.side-bar').addClass('slide-in');


                    $('.nav-text.d-block').fadeOut();

                })

                $('#navbar-left').hover(function () {
                    $('.slide-in').removeClass('slide-in');
                    $('.nav-text.d-block').fadeIn(1000);
                });
                $('.RadGrid').addClass('card new-design border');
                $('#divRadGrid1, #divRadGrid').removeClass('border');

                $('body').on('click', function () {
                    $('.nav-item.active').removeClass('active');
                })

                if ($('body').width() <= 1300)

                    $(document).on('click', '#navbar-left .nav-item', function () {
                        $('#navbar-left-child').attr('style', 'display: block !important');
                    })


                $(`body`).append(`
			
   <link rel="stylesheet" type="text/css" href="../../../CSS/new-design.css?ver=20251124" />

			`);

            } else {
                $(document).on('click', '#navbar-left a', function () {
                    $('#navbar-left-child').attr('style', 'display: block !important');
                    console.log('.....test......');
                })
                $('#navbar-left-child').attr('style', 'display: block !important');
                console.log('.....test......');
            }

            $(document).on('click', '.childNav a', function () {
                var href = $(this).attr('href');
                if (href && href !== '' && href != 'void(0)')
                    document.location.href = $(this).attr('href')
            })

            if (__logo !== '')
                $('#logo-cu').attr('src', __logo.replace("~", ''))
            if (__primaryColor && __primaryColor.SwitchMenu)
                $('body').append(`

            <style id="custom-theme">

.sidebar-left-secondary a, .sidebar-left-secondary a .nav-icon {
 color: ${__primaryColor.SecondarySubColor} !important
}
.layout-sidebar-large .main-header .menu-toggle div {
background:${__primaryColor.HeaderFontColor} !important
}
.main-header {
background-color: ${__primaryColor.HeaderColor} !important; color:${__primaryColor.HeaderFontColor} !important
}
.main-header a {
color:${__primaryColor.HeaderFontColor} !important
}
#navbar-left .nav-item .dropdown-menu-right a span {
color:${__primaryColor.SecondarySubColor} !important
}
#navbar-left, #navbar-left li a.nav-item-hold,
.layout-sidebar-large .sidebar-left .navigation-left .nav-item
{background-color: ${__primaryColor.PrimaryColor} !important; color:${__primaryColor.SecondaryColor} !important }

.layout-sidebar-large .sidebar-left .navigation-left .nav-item.active , .layout-sidebar-large .sidebar-left .navigation-left .nav-item.digselected {
    border-right: 5px solid ${__primaryColor.SecondaryColor} !important;
}
.layout-sidebar-large .sidebar-left-secondary .childNav li.nav-item a ,
.layout-sidebar-large .sidebar-left-secondary .childNav li.nav-item a .nav-icon ,
.layout-sidebar-large .sidebar-left-secondary .childNav li.nav-item a span
{
color:${__primaryColor.SecondaryColor}
}
.RadToolBar, .bg-theme-primary  {
    background-color: ${__primaryColor.TertiaryColor} !important;
 color: ${__primaryColor.TertiaryFontColor} !important;
}
.bg-theme-primary span {
 color: ${__primaryColor.TertiaryFontColor} !important;
}
.RadToolBar ul li {
    color: ${__primaryColor.TertiaryFontColor};
}
.btn-themed, .reSelectedMode {
    background-color: ${__primaryColor.PrimaryButtonColor ? __primaryColor.PrimaryButtonColor : __primaryColor.TertiaryColor} !important;
    color: ${__primaryColor.TertiaryFontColor} !important;
    font-weight: bold;
}
.RadTabStrip .rtsUL .rtsLI.rtsSelected{
	border-bottom: 0px !important;
	padding-bottom: 3px !important;
    border-bottom: 2px solid  ${__primaryColor.PrimaryButtonColor ? __primaryColor.PrimaryButtonColor : __primaryColor.TertiaryColor} !important;
}

.reSelectedMode {
 border-color:  ${__primaryColor.PrimaryButtonColor ? __primaryColor.PrimaryButtonColor : __primaryColor.TertiaryColor} !important;
}
.btn-themed  *, .btn-themed , .reSelectedMode, .reSelectedMode *{
 color: ${__primaryColor.PrimaryButtonFontColor ? __primaryColor.PrimaryButtonFontColor : __primaryColor.TertiaryFontColor} !important;
}

.btn-themed  i, .reSelectedMode i{
    color: ${__primaryColor.PrimaryButtonFontColor ? __primaryColor.PrimaryButtonFontColor : __primaryColor.TertiaryFontColor} !important;
}
</style>
        `)
        }

        function showNotification() {

            loadNotificationData();

            manualRightModal('#alerts-side-bar');

        }

        function showSrvQTB() {
            var chkSrvQ = document.getElementById('<%=SrvQ.ClientID%>');
            if (chkSrvQ.checked) {
                $('#<%=dsrvq.ClientID%>').removeClass('d-none');
            }
            else {
                document.getElementById('<%=SrvQTB.ClientID%>').value = "";
                $('#<%=dsrvq.ClientID%>').addClass('d-none');
            }
        }

        function showDifUTB() {
            var chkDifU = document.getElementById('<%=DifU.ClientID%>');
            if (chkDifU.checked) {
                $('#<%=ddifu.ClientID%>').removeClass('d-none');
            }
            else {
                document.getElementById('<%=DifUTB.ClientID%>').value = "";
                $('#<%=ddifu.ClientID%>').addClass('d-none');
            }
        }

        function showNotLTB() {
            var chkNotL = document.getElementById('<%=NotL.ClientID%>');
            if (chkNotL.checked) {
                $('#<%=dnotl.ClientID%>').removeClass('d-none');
            }
            else {
                document.getElementById('<%=NotLTB.ClientID%>').value = "";
                $('#<%=dnotl.ClientID%>').addClass('d-none');
            }
        }

        function showTExpTB() {
            var chkTExp = document.getElementById('<%=TExp.ClientID%>');
            if (chkTExp.checked) {
                $('#<%=dtexp.ClientID%>').removeClass('d-none');
            }
            else {
                document.getElementById('<%=TExpTB.ClientID%>').value = "";
                $('#<%=dtexp.ClientID%>').addClass('d-none');
            }
        }

        function showOtherTB() {
            var chkOthr = document.getElementById('<%=Othr.ClientID%>');
            if (chkOthr.checked) {
                $('#<%=dothr.ClientID%>').removeClass('d-none');
            }
            else {
                document.getElementById('<%=OthrTB.ClientID%>').value = "";
                $('#<%=dothr.ClientID%>').addClass('d-none');
            }
        }

        function sortMeBy(arg, sel, elem, order) {
            var $selector = $(sel),
                $element = $selector.children(elem);
            $element.sort(function (a, b) {
                var an = parseInt(a.getAttribute(arg)),
                    bn = parseInt(b.getAttribute(arg));
                if (order == "asc") {
                    if (an > bn)
                        return 1;
                    if (an < bn)
                        return -1;
                } else if (order == "desc") {
                    if (an < bn)
                        return 1;
                    if (an > bn)
                        return -1;
                }
                return 0;
            });
            $element.detach().appendTo($selector);
        }
        //loadNotificationData()

        $('#search-alerts').on('keyup', function () {
            loadNotificationData();
        })
        function loadNotificationData() {
            var search = $('#search-alerts').val();
            var conditions = `(StoreID = ${__appGullStoreId}) and (Title like '%${search}%' or ResponsibleDisplay like '%${search}%' 
or DateDisplay like '%${search}%'
or ModuleBadge like '%${search}%'
or Details like '%${search}%'
or FirstName like '%${search}%'
or LastName like '%${search}%'
)`;

            if (__isCompany === "False") {
                conditions = `(StoreID = ${__appGullStoreId} and StoreUserID = ${jmemberData.StoreUserID}) and (Title like '%${search}%' or ResponsibleDisplay like '%${search}%' 
or DateDisplay like '%${search}%'
or ModuleBadge like '%${search}%'
or Details like '%${search}%'
or FirstName like '%${search}%'
or LastName like '%${search}%'
)`;

            }
            var search = $('#search-alerts').val();
            jQuery.ajax({
                type: "POST",
                url: "../../NetServices/PostDynamicChecklist.asmx/spGenerateTableJSONv2",
                data: JSON.stringify({
                    data: {
                        TableName: "__notifications",
                        Condition: conditions,
                        Fields: "RegOthID,Title, RecordLink, DateDisplay, ResponsibleDisplay, ModuleBadge, Details,DateOrder, StoreUserID, FirstName, LastName",
                        Limit: 100000,
                        OrderBy: " DateOrder desc ",
                        CurPage: 1
                    }
                }),
                dataType: "JSON",
                contentType: 'application/json'
            }).done(function (next) {
                $(`#alert-container`).html('');
                var dataAlerts = JSON.parse(next.d.JsonValue);
                $.each(dataAlerts, function (i, e) {
                    if ($(`#record-id-${e.RegOthID}`).length === 0)
                        $(`#alert-container`).append(createNotifCard(e, dataAlerts));
                });





                if (dataAlerts.length > 9) {

                    $('#rightMenu2000').after(`<span onclick="  showNotification()" class="d-none badge badge-danger number-of-widget" style="
    position: absolute;
    right: 0px;
    bottom: 0px;
	opacity:.8;
cursor: pointer;
">9+</span>`)
                } else {

                    $('#rightMenu2000').after(`<span onclick="  showNotification()" class="d-none badge badge-danger number-of-widget" style="
    position: absolute;
    right: 0px;
    bottom: 0px;
	opacity:.8;
cursor: pointer;
">${dataAlerts.length}</span>`)

                }





            });

        }


        function createNotifCard(e, dataAlerts) {

            var list = getViewedAlerts();
            var fcnf = $.grep(list, function (n) {
                return n === e.RecordLink;
            }, false)[0];


            var recs = $.grep(dataAlerts, function (n) {
                return n.RegOthID === e.RegOthID;
            }, false);
            var ps = `
<div id="worker-${e.RegOthID}-${e.StoreUserID}" style="width:25px; height:25px">
                                ${e.ResponsibleDisplay}
                            </div>
`;
            var ctr = 1;
            if (recs.length > 1) {
                var storeUserIDs = [];
                ps = '';
                var names = ``;

                $.each(recs, function (i, e) {
                    var wor = $.grep(storeUserIDs, function (n) {
                        return n === e.StoreUserID;
                    }, false);
                    if (wor.length === 0) {
                        if (ctr <= 3) {
                            ctr++;
                            storeUserIDs.push(e.StoreUserID);

                            ps += `

                    <div id="worker-${e.RegOthID}-${e.StoreUserID}" style="width:30px" class="ml-1">
                     ${e.ResponsibleDisplay}                        
                    </div>
                `;
                        }
                        else {
                            ctr++;
                            storeUserIDs.push(e.StoreUserID);
                            names += `${e.FirstName} ${e.LastName} \r\n`
                            //console.log(names)
                        }
                    }
                })

                if (names !== '') {
                    ps += `
                  <div  style="width:25px; height:25px" class="ml-1">
 <div title="${names}" style="max-width:30px;border-radius:50%;padding: 5px 1px 5px 1px;/* height:40px; *//* width:40px; */text-align: center;font-size: 10px;" class="bg-primary font-weight-bold text-white">+${ctr - 4} </div>
                 
             
                    </div>
                `;
                }

            }



            var isActive = '';

            if (fcnf) {
                isActive = 'bg-f2f3f5';
            }



            return `
                    <div id="record-id-${e.RegOthID}" dateorder="${e.DateOrder}" onclick="alertRecordLink('${e.RecordLink}')" style="border-bottom: 1px solid rgba(0, 0, 0, 0.03) !important" class="p-2 alert-item ${isActive}">
                                <div class="mb-1">
                                    ${e.ModuleBadge}
                                </div>
                        <div class="d-flex justify-content-between pl-1">
                            <div style="max-width:300px; font-size: 11px">
                                <div>
                                    ${e.Title}
                                </div>
                                 <div class="small">
                                    ${e.Details}
                                </div>
                                <div class="small" style="color:#aaa!important;">
                                     ${e.DateDisplay}
                                </div>
                            </div>
<div style="position:relative">
<div style="
    position: absolute;
    bottom: 5px;
    right: 5px;
" class="d-flex justify-content-end">
                            ${ps}
</div>
</div>
                        </div>
                    </div>
                `
        }

        function alertRecordLink(l) {
            setViewedAlerts(l)
            if (l !== '')
                document.location.href = l;
            else
                closeAllRightModal();
        }

        function getViewedAlerts() {
            var viewed = localStorage.getItem('viewed-alerts');
            try {
                var a = JSON.parse(viewed);
                return a === null ? [] : a;
            } catch (e) {
                return [];
            }
        }
        function setViewedAlerts(l) {
            var selected;
            try {
                selected = getViewedAlerts();
            } catch (e) {
                selected = [];
            }

            selected.push(l);
            localStorage.setItem('viewed-alerts', JSON.stringify(selected))
        }

        //TEST FOR Member commit
        checkMember();

        function checkMember() {
            jQuery.ajax({
                type: "GET",
                url: "../../NetServices/POSTDynamicChecklist.asmx/MemberShowCommitBtn",
                dataType: "JSON",
                contentType: 'application/json'
            }).done(function (e) {
                if (e.d === 1) {
                    $('#BtnCommitTransaction').removeClass('d-none');
                    $('#wcCancelSub').removeClass('d-none');
                } else if (e.d === 2) {
                    CommitSubscriptionProceed(2);
                }
                else { }
            });


            //Agtech.Web.UI.NetServices.PostDynamicChecklist.MemberShowCommitBtn(function (e) {
            //    if (e) {
            //    } else {
            //        document.getElementById("BtnCommitTransaction").style.visibility = 'hidden';
            //    }
            //}, OnFailed);
        }

        function CommitSubscription() {
            $('#confirm-subscription').removeClass('d-none');
            manualRightModal('#confirm-subscription');
        }

        function CancelSubscription() {
            //$('#confirm-cancel-subscription').removeClass('d-none');
            clearFeedbacks();
            $('#cancel-subscription').removeClass('d-none');
            manualRightModal('#cancel-subscription');
        }

        function clearFeedbacks() {
            var chkSrvQ = document.getElementById('<%=SrvQ.ClientID%>');
            var chkDifU = document.getElementById('<%=DifU.ClientID%>');
            var chkNotL = document.getElementById('<%=NotL.ClientID%>');
            var chkTExp = document.getElementById('<%=TExp.ClientID%>');
            var chkOthr = document.getElementById('<%=Othr.ClientID%>');

            chkSrvQ.checked = false; document.getElementById('<%=SrvQTB.ClientID%>').value = ""; $('#<%=dsrvq.ClientID%>').addClass('d-none');
            chkDifU.checked = false; document.getElementById('<%=DifUTB.ClientID%>').value = ""; $('#<%=ddifu.ClientID%>').addClass('d-none');
            chkNotL.checked = false; document.getElementById('<%=NotLTB.ClientID%>').value = ""; $('#<%=dnotl.ClientID%>').addClass('d-none');
            chkTExp.checked = false; document.getElementById('<%=TExpTB.ClientID%>').value = ""; $('#<%=dtexp.ClientID%>').addClass('d-none');
            chkOthr.checked = false; document.getElementById('<%=OthrTB.ClientID%>').value = ""; $('#<%=dothr.ClientID%>').addClass('d-none');
            document.getElementById('<%=wcFeedbackCommentTb.ClientID%>').value = "";
        }

        function ConfirmCancelSubscription() {
            var chkSrvQ = document.getElementById('<%=SrvQ.ClientID%>');
            var chkDifU = document.getElementById('<%=DifU.ClientID%>');
            var chkNotL = document.getElementById('<%=NotL.ClientID%>');
            var chkTExp = document.getElementById('<%=TExp.ClientID%>');
            var chkOthr = document.getElementById('<%=Othr.ClientID%>');

            if (chkSrvQ.checked) {
                if (document.getElementById('<%=SrvQTB.ClientID%>').value.trim() === "") {
                    $('#requireFeedback').removeClass('d-none');
                    return false;
                }
            }
            if (chkDifU.checked) {
                if (document.getElementById('<%=DifUTB.ClientID%>').value.trim() === "") {
                    $('#requireFeedback').removeClass('d-none');
                    return false;
                }
            }
            if (chkNotL.checked) {
                if (document.getElementById('<%=NotLTB.ClientID%>').value.trim() === "") {
                    $('#requireFeedback').removeClass('d-none');
                    return false;
                }
            }
            if (chkTExp.checked) {
                if (document.getElementById('<%=TExpTB.ClientID%>').value.trim() === "") {
                    $('#requireFeedback').removeClass('d-none');
                    return false;
                }
            }
            if (chkOthr.checked) {
                if (document.getElementById('<%=OthrTB.ClientID%>').value.trim() === "") {
                    $('#requireFeedback').removeClass('d-none');
                    return false;
                }
            }

            $('#requireFeedback').removeClass('d-none').addClass('d-none');
            $('#cancel-subscription').addClass('d-none');
            $('#confirm-cancel-subscription').removeClass('d-none');

            manualRightModal('#confirm-cancel-subscription');
            //$('#confirm-cancel-subscription').removeClass('d-none');
            //jQuery.ajax({
            //    type: "GET",
            //    url: "../../NetServices/POSTDynamicChecklist.asmx/CancelSubscription",
            //    dataType: "JSON",
            //    contentType: 'application/json'
            //}).done(function () {
            //    closeAllRightModal();
            //    $('#cancel-subscription').removeClass('d-none');
            //    manualRightModal('#cancel-subscription');
            //});
        }

        function CommitSubscriptionProceed(stat) {
            $('#confirm-subscription').html(`<div class="center-page"><div class="loader spinner-bubble spinner-bubble-primary"></div></div>`);
            //setTimeout(function () {
            jQuery.ajax({
                type: "GET",
                url: "../../NetServices/POSTDynamicChecklist.asmx/CommitToSubscription?stat=" + stat,
                dataType: "JSON",
                contentType: 'application/json'
            }).done(function () {
                if (stat === 2) {
                    $('#over30').removeClass('d-none');
                } else {
                    $('#under30').removeClass('d-none');
                }
                $('#confirm-subscription').addClass('d-none');
                $('#BtnCommitTransaction').addClass('d-none');
                $('#wcCancelSub').addClass('d-none');
                $('#commit-subscription').removeClass('d-none');
                manualRightModal('#commit-subscription');
            });
            //}, 10000);
        }

        function Subscription(p) {
            if (p == 'all') {
                jQuery.ajax({
                    type: "GET",
                    url: "../../NetServices/POSTDynamicChecklist.asmx/DeleteAllTestDataCommitSubscription",
                    dataType: "JSON",
                    contentType: 'application/json'
                }).done(function () {
                    location.reload();
                });
            } else if (p == 'module') {
                var storeId = '<%=Agtech.Web.UI.Utility.GetCurrentStoreID() %>';
                document.location.href = "../../App/Farm/AddEditFarm.aspx?Page=500&Store=" + storeId + "#RemoveTestData";
            }
            else if (p == 'skip') {
                closeAllRightModal();
            }
        }


        function showDeleteRecords() {
            $('#frame').remove();
            $('#commit-subscription').addClass('d-none');
            manualRightModal('#sample-records-modal');
            $('#sample-records-wrapper').html(`<iframe id="frame"  src='../../App/Admin/SetupCustomData.aspx' class="w-100 border-0" style="height:85%" />`);
        }

