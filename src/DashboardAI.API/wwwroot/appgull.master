					<script>
                        function changeTour(tourId) {
                            closeAllRightModal();
                            // Flow ID maps (publish status + targeting must allow this page/user)
                            const MAP_ON = {
                                'compliance-management': 'f2fbd315-14bf-45fe-9656-71139136f6d8',
                                'people': 'ef509f29-238b-4722-ac48-6ab95311944f',
                                'business-risks': 'ba8c8394-f9f7-4b0e-819c-f1cb0f5ee9f5',
                                'whs-risks': 'ba8c8394-f9f7-4b0e-819c-f1cb0f5ee9f5',
                                'whs-incident': '2961375d-0d04-4c20-9835-4f39252be5f2',
                                'whs-contractor': '2f5fd6a8-f0a4-4383-a548-d6b4a3fbaa82',
                                'asset-safety': 'a63f9e81-52ef-4d84-beb4-727422088f4f',
                                'chemicals': '53fdb1b5-2ba5-4287-be0a-8ed85b8c8d99',
                                'farm-operations': '2fbd315-14bf-45fe-9656-71139136f6d8'
                            };

                            const MAP_OFF = {
                                'compliance-management': 'd623c95d-6eda-493b-be77-eb461230c01a',
                                'people': '5b5b1b8f-3781-4bfc-83a2-e26f56364017',
                                'business-risks': 'f9479410-3a6b-48b1-b5a8-836a49b1201a',
                                'whs-risks': 'f9479410-3a6b-48b1-b5a8-836a49b1201a',
                                'whs-incident': 'f65c9ea1-e6e5-41a1-b2a3-3cecb2f10019',
                                'whs-contractor': '76bb4088-d5eb-4352-bab6-274fd7bf198b',
                                'asset-safety': 'fa1c3f9d-efad-4cea-bec2-9aa5f8cb8e28',
                                'chemicals': '505d0ab2-2acd-4d02-8d9c-81f0dd5a73b5',
                                'farm-operations': '2fbd315-14bf-45fe-9656-71139136f6d8'
                            };

                            const map = (__primaryColor && __primaryColor.SwitchMenu) ? MAP_ON : MAP_OFF;
                            const flowId = map[tourId];

                            if (!flowId) {
                                console.warn('[Appcues] No flow ID mapped for tourId:', tourId);
                                return;
                            }
                            if (!window.Appcues) {
                                console.warn('[Appcues] SDK not loaded yet');
                                return;
                            }

                            // Optional: keep a breadcrumb of what user asked for
                            try {
                                if (window.jmemberData && jmemberData.UserName) {
                                    window.Appcues.identify(jmemberData.UserName, { selectedTour: tourId, selectedFlowId: flowId });
                                }
                            } catch (e) {
                                console.warn('[Appcues] identify() failed:', e);
                            }

                            // If you're on an SPA and just navigated, you may need to notify Appcues of the route change first.
                            // Example (uncomment if needed):
                            // Appcues.page(); // or Appcues.page('/current/path');

                            // Finally, launch the flow
                            window.Appcues.show(flowId);
                        }


                      

                    </script>
