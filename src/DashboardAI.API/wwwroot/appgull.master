                        $('body').append(`<style> [refkey="GA"] {display:none !important} </style>`)
                        __actCnt--;
                    }

                    if ($('#apage-746').length < 1) {
                        $('body').append(`<style> [refkey="GA"] {display:none !important} </style>`)
                        __activityCnt--;
                    }
                    if (__activityCnt === 0) {
                        $('body').append(`<style> #apage-1050 {display:none !important} </style>`)

                    }
                    if (_astsCntModule === 0) {
                        $('body').append(`<style> #apage-1047 {display:none !important} </style>`)

                    }
                    if (_astsCntSafety === 0) {
                        $('body').append(`<style> #apage-1048 {display:none !important} </style>`)
                    }

                    if (_astsCntModule === 0 && _astsCntSafety === 0) {
                        $('body').append(`<style> #apage-713 {display:none !important} </style>`)
                    }

                })
                __sideBarIsLoaded = true;
            }
            else {
                $.ajax({
                    type: "POST",
                    url: `<%=GetMenus()%>`,
                    async: true,
                }).done(function (data) {
                    menuData = data;
                    loadRightSideMenu();
