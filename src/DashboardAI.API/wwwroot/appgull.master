        <div class="app-admin-wrap layout-sidebar-large clearfix">
            <div class="main-header">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between w-100 gap-3">
                        <%-- Logo and navigation section --%>
                        <div class="d-flex align-items-center" style="min-width: 0; flex-shrink: 0;">
                            <div  style="position: relative;   top: -4px;" class="logo">
                                <img id="logo-cu" src="/App_Themes/<%= Page.Theme %>/Images/theme-logo.png?ver=20241122" />
                            </div>
                            <div class="logo-buttons d-flex align-items-center">
                                <div class="menu-toggle">
                                    <div></div>
                                    <div></div>
                                    <div></div>
                                </div>
                                <div class="d-flex align-items-center">
                                    <a  style="position: relative;top: -4px;" title="Home" id="homeLink" href="#"><i style=" font-size: 1.8rem;" class="icon-arventa-home header-icon d-sm-inline-block menu-btn"></i></a>
                                    <div id="btnSwitchAccount" class="ml-2">
                                  
                                    </div>
                                </div>
                            </div>
                        </div>

                        <%-- AI button --%>
                        <div class="d-flex align-items-center mr-2" style="flex-shrink: 0;">
                            <button type="button" onclick="manualRightModal('#generate-ai')" class="btn btn-themed btn-lg d-flex align-items-center gap-1" title="AI Assistant" style="height:42px;;white-space:nowrap;font-weight:600;letter-spacing:.5px;">
                                <i class="icon-arventa ph ph-thin ph-magic-wand mr-1" style="position:relative; top:0px !important;"></i>
                                <span style="    font-weight: normal;">AI Mode</span>
                            </button>
                        </div>

                        <%-- Search column - grows to fill available space --%>
                        <div class="flex-grow-1" style="min-width: 0;">
                            <div class="header-search-wrapper" style="position: relative;">
                                <i class="ph ph-thin ph-magnifying-glass  header-search-icon-left"></i>
                                <div id="header-autocomplete"></div>
                                <button class="header-search-btn" id="headerSearchBtn">
                                    <i class="iconsmind-Magnifi-Glass2"></i>
                                </button>
                            </div>
                        </div>

                        <%-- Right header items --%>
                        <div class="d-flex align-items-center" style="flex-shrink: 0;">
                            <div style="position: relative;top: -4px;" class="header-part-right d-flex align-items-center gap-2">
                                <div class="d-none">
                                    <button onclick="document.location.href='https://app.whsmonitor.com.au/App/Dashboard/Dashboard.aspx?appcue=8365626c-3ad4-4768-8f33-910d4d1f84ee'" style="background-color: rgb(0, 123, 255) !important; color: #fff !important" type="button" class="btn btn-themed pt-2">💡 Launch Update Tour</button>
                                </div>
								
							
								
                                <div id="BtnCommitTransaction" class="ml-2 flex-grow d-none">
                                    <button type="button" onclick="CommitSubscription()" class="btn btn-themed">
                                        <span>Start Full Subscription</span>
                                    </button>
                                </div>


                                <!-- Full screen toggle -->
                                <i title="Full screen" class="iconsmind-Full-Screen header-icon d-none d-sm-inline-block" data-fullscreen></i>
                                <!-- Full screen toggle end -->
                                <!-- Grid menu Dropdown -->
                                <div class="dropdown d-none" id="menuQuickLinksWrapper">
                                    <i class="icon-arventa-risk_monitor header-icon menu-quick-links-btn" id="dropdownMenuButton" data-toggle="dropdown"
                                        aria-haspopup="true" role="button" aria-expanded="false"></i>
                                    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuButton">
                                        <div class="menu-icon-grid text-center" id="menuQuickLinks"></div>
                                    </div>
                                </div>
                                <!-- Grid menu Dropdown end -->

                                <span id="rightMenu"></span>

                                <!-- Notification -->
                                <%--<div class="dropdown">
                                    <div class="badge-top-container" id="dropdownNotification" role="button" data-toggle="dropdown"
                                        aria-haspopup="true" aria-expanded="false">
                                        <span class="badge badge-primary">3</span>
                                        <i class="iconsmind-Bell text-muted header-icon"></i>
                                    </div>
                                    <!-- Notification dropdown -->
                                    <div class="dropdown-menu rtl-ps-none dropdown-menu-right notification-dropdown"
                                        aria-labelledby="dropdownNotification" data-perfect-scrollbar data-suppress-scroll-x="true">
                                        <div class="dropdown-item d-flex">
                                            <div class="notification-icon">
                                                <i class="iconsmind-Speach-Bubble-6 text-primary mr-1"></i>
                                            </div>
                                            <div class="notification-details flex-grow-1">
                                                <p class="m-0 d-flex align-items-center">
                                                    <span>New message</span>
                                                    <span class="badge badge-pill badge-primary ml-1 mr-1">new</span>
                                                    <span class="flex-grow-1"></span>
                                                    <span class="text-small text-muted ml-auto">10 sec ago</span>
                                                </p>
                                                <p class="text-small text-muted m-0">James: Hey! are you busy?</p>
                                            </div>
                                        </div>
                                        <div class="dropdown-item d-flex">
                                            <div class="notification-icon">
                                                <i class="iconsmind-Receipt-3 text-success mr-1"></i>
                                            </div>
                                            <div class="notification-details flex-grow-1">
                                                <p class="m-0 d-flex align-items-center">
                                                    <span>New order received</span>
                                                    <span class="badge badge-pill badge-success ml-1 mr-1">new</span>
                                                    <span class="flex-grow-1"></span>
                                                    <span class="text-small text-muted ml-auto">2 hours ago</span>
                                                </p>
                                                <p class="text-small text-muted m-0">1 Headphone, 3 iPhone x</p>
                                            </div>
                                        </div>
                                        <div class="dropdown-item d-flex">
                                            <div class="notification-icon">
                                                <i class="iconsmind-Empty-Box text-danger mr-1"></i>
                                            </div>
                                            <div class="notification-details flex-grow-1">
                                                <p class="m-0 d-flex align-items-center">
                                                    <span>Product out of stock</span>
                                                    <span class="badge badge-pill badge-danger ml-1 mr-1">3</span>
                                                    <span class="flex-grow-1"></span>
                                                    <span class="text-small text-muted ml-auto">10 hours ago</span>
                                                </p>
                                                <p class="text-small text-muted m-0">Headphone E67, R98, XL90, Q77</p>
                                            </div>
                                        </div>
                                        <div class="dropdown-item d-flex">
                                            <div class="notification-icon">
                                                <i class="iconsmind-Data-Power text-success mr-1"></i>
                                            </div>
                                            <div class="notification-details flex-grow-1">
                                                <p class="m-0 d-flex align-items-center">
                                                    <span>Server Up!</span>
                                                    <span class="badge badge-pill badge-success ml-1 mr-1">3</span>
                                                    <span class="flex-grow-1"></span>
                                                    <span class="text-small text-muted ml-auto">14 hours ago</span>
                                                </p>
                                                <p class="text-small text-muted m-0">Server rebooted successfully</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>--%>
                                <!-- Notification End -->

                                <!-- User avatar dropdown -->
                                <div class="dropdown">
                                    <div class="user col align-self-end">
                                        <%-- TODO: Show this when there is no user icon --%>
                                        <i title="User profile" id="userDefaultIconDropdown" class="icon-arventa-user_profile header-icon menu-btn"
                                            role="button"
                                            data-toggle="dropdown"
                                            aria-haspopup="true"
                                            aria-expanded="false"></i>

                                        <%-- TODO: Show this when there is user icon --%>
                                        <%--<img src="../theme-assets/01/images/faces/1.jpg" id="userDropdown" alt="" data-toggle="dropdown"
                                            aria-haspopup="true" aria-expanded="false">--%>

                                        <div class="dropdown-menu dropdown-menu-right" aria-labelledby="userDropdown">

                                            <div style="color: #3b5998!important" class="dropdown-header  px-3 py-2">
                                                <i style="position: relative; top: 5px; font-size: 20px;" class="iconsmind-Lock-User mr-1"></i><span style="font-size: 12px;"><%= GetCurrentUserName()%></span>
                                            </div>

                                            <a class="pl-3 dropdown-item" href="#" data-toggle="modal" data-target=".modal-account-summary">Account summary</a>
                                            <a class="pl-3 dropdown-item" href="../../App/Admin/ManageSubscriptionInfo.aspx">Subscription info</a>
                                            <a id="wcCancelSub" class="pl-3 dropdown-item d-none" href="#" onclick="CancelSubscription()">Cancel Subscription</a>

                                            <asp:LinkButton ID="wcSignOutBtn" runat="server"
                                                CssClass="dropdown-item wcSignOutBtn"
                                                OnClick="wcSignOutBtn_Click"
                                                ValidationGroup="HeaderSignOut"
                                                CausesValidation="false">
                                                Sign out
                                            </asp:LinkButton>

                                        </div>
                                    </div>
                                </div>
                                <!-- User avatar dropdown end -->
                            </div>
                        </div><!-- right header items end -->
                    </div><!-- d-flex end -->
                </div><!-- container-fluid end -->
            </div><!-- main-header end -->
            <!--=============== Main header End ================-->

            <div class="side-content-wrap" id="sideContentWrap">
			
			
				

                <div class="sidebar-left open slide-in rtl-ps-none" data-perfect-scrollbar="" data-suppress-scroll-x="true">
                    <ul class="navigation-left slide-in" id="navbar-left"></ul>
					<div  id="mob-overlay" class="d-none" style="z-index: 1; background: #000; height: 100%; width: 100%; position: fixed; left: 0; top: 0; opacity: .7"></div>
                </div>

                <div class="sidebar-left-secondary rtl-ps-none" data-perfect-scrollbar="" data-suppress-scroll-x="true" id="navbar-left-child"></div>

                <div class="sidebar-overlay-disabled"></div>

            </div>
            <!--=============== Left side End ================-->

            <!-- ============ Body content start ============= -->

            <div class="main-content-wrap sidenav-open d-flex flex-column">

                <%-- BreadCrumbs --%>
                <div id="breadcrumbs" class="breadcrumbs-20 d-none">
                    <div class="d-flex justify-content-between border-bottom">
                        <div class="pb-2  breadcrumbs-parent">
                            <span class="breadcrumbs-header h4 m-0 text-uppercase font-weight-bold"></span>
                            <span class="breadcrumbs-separator h4 m-0 pl-3 pr-2 ">|</span>
                            <div class="d-lg-inline-block pt-2 p-lg-0 align-items-center breadcrumbs-navigations jiggers"></div>
                        </div>
                        <div>
                            <asp:ContentPlaceHolder ID="headerbuttons" Visible="true" runat="server"></asp:ContentPlaceHolder>
                        </div>
