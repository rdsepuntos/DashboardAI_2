        if (rstring !== '') {
            hash = '';
            switchSkip();
        }
        if (hash != 'prev' && (skip === "" && jmemberData.ShowOnBoarding && jmemberData.IsNew && document.location.href.toLocaleLowerCase().indexOf('onboardingv2') === -1)) {
            if ($('body').width() > 600)
                $(`body`).append(`<div id="onboarding-popup" style="position: fixed; top: 0px; left: 0px; height: 100%; width: 100%; z-index: 5000">

<iframe src="../../App/Help/OnboardingV2.aspx" style="height: 100%; width: 100%; border:0px" scrolling="no" />

</div>`)
