            function loadRightSideMenu() {
                $(menuData.Menus.Menu).each(function (index, menu) {
                    if (__primaryColor.SwitchMenu) {
                        if (menu.PageCaption === 'Dashboard / Reporting') {
                            menu.PageCaption = 'Reporting'
                        }
                        if (menu.PageCaption === 'Compliance Management') {
                            menu.PageCaption = 'Compliance'
                        }

                    }
                    if (menu.PageID === '660') {
                        // Create home link
                        $('#homeLink').attr("href", menu.PageLink);
                    } else if (menu.ShowRightMenu === 'false') {
                        // Create sidebar menus
                        var dataItem = '';
                        var dataPanel = '';
                        var isStaticDashboard = false;

                        //TODO: Only show sub menu when not static dashboard
                        if (menu.Menu && !isStaticDashboard) {
                            dataItemName = 'sidebarMenu' + menu.PageID;
                            if (menu.IsPanel === 'true' && (menu.IsPanelStatic === 'true' || menu.IsPanelDynamic === 'true')) {
                                dataPanel = 'data-panel="true"';
                            } else {
                                dataItem = 'data-item="' + dataItemName + '"';
                                setSidebarSubMenu(menu.Menu, dataItemName, menu.PageCaption);
                            }
                        }

                        icon = menu.PageIcon === '' || menu.PageIcon === null ? 'iconsmind-Bar-Chart' : menu.PageIcon;


                        $('#navbar-left').append(
                            '<li class="nav-item" ' + dataItem + ' ' + dataPanel + '>' +
                            '<a class="nav-item-hold" ' + setPageLink(menu) + '">' +
                            '<i class="nav-icon ' + icon + ' "></i>' +
                            '<span class="nav-text">' + menu.PageCaption + '</span>' +
                            '</a>' +
                            '</li>'
                        );
                    } else {
                        // Create top right menu
                        rightMenuId = 'rightMenu' + menu.PageID;
                        rightMenuSubNav = '';

                        if (menu.Menu) {
                            rightMenuSubNav = setTopRightSubMenu(menu.Menu);


                        }

                        icon = menu.PageIcon === '' || menu.PageIcon === null ? 'iconsmind-Information' : menu.PageIcon;

                        if (menu.IsPanel === 'true' && (menu.IsPanelStatic === 'true' || menu.IsPanelDynamic === 'true')) {
                            $('#rightMenu').before(
                                '<a title="' + menu.PageCaption + '" id="' + rightMenuId + '" href="' + menu.PanelUrl + '"><i class="' + icon + ' header-icon menu-quick-links-btn"></i></a>'
                            );
                        } else {
                            $('#rightMenu').before(
                                '<div class="dropdown">' +
                                '<i title="' + menu.PageCaption + '" class="' + icon + ' header-icon right-menu-btn" id="' + rightMenuId + '" data-toggle="dropdown" aria-haspopup="true" role="button" aria-expanded="false"></i>' +
                                '<div class="dropdown-menu dropdown-menu-right" aria-labelledby="' + rightMenuId + '">' +
                                rightMenuSubNav +
                                '</div>' +
                                '</div>'
                            );
                            $('#rightMenu603').attr('onclick', 'document.location.href="https://app.whsmonitor.com.au/App/Help/AppHelp.aspx?Page=605";');
                            $('[aria-labelledby="rightMenu603"]').remove();
                            if ($('a[name="Training Videos"]').length === 1) {
                                $('#rightMenu603').attr('onclick', 'document.location.href="https://app.whsmonitor.com.au/App/Help/AppHelp.aspx?Page=605";');
                                $('[aria-labelledby="rightMenu603"]').remove();
                                $('a[name="Training Videos"]').after(`
									 <a class="dropdown-item px-3" target="_blank" href="https://www.whsmonitor.com.au/saml/IdPLauncher.aspx?Page=605"> <span class="font-weight-bold theme-border-left-5">Knowledge Base</span></a>
                                
                                    <a class="dropdown-item px-3"  href="https://www.whsmonitor.com.au/App/Help/AppHelp.aspx?Page=605"> <span class="font-weight-bold theme-border-left-5">Submit Support Ticket</span></a>
								`);
                            }
                            else {
                                $('[aria-labelledby="rightMenu603"]').prepend(`
									 <a class="dropdown-item px-3" target="_blank" href="https://www.whsmonitor.com.au/saml/IdPLauncher.aspx?Page=605"> <span class="font-weight-bold theme-border-left-5">Knowledge Base</span></a>
                                
                                    <a class="dropdown-item px-3"  href="https://www.whsmonitor.com.au/App/Help/AppHelp.aspx?Page=605"> <span class="font-weight-bold theme-border-left-5">Submit Support Ticket</span></a>
								`);
                            }



                            $('a[name="Help"]').attr('href', 'javascript:void(0)');
                            $('a[name="Help"]').attr('onclick', `manualRightModal2('#help-file');`)

                            if (!opt[0].EnableHelp) {
                                $('#rightMenu603').parent().remove();
                            }

                            $('#rightMenu603').attr('onclick', 'document.location.href="#whshelp"')

                            $('[aria-labelledby="rightMenu2000"]').remove();



                        }
                    }

                    loadCovid();

                    $('#rightMenu2000').off('click').on('click', function () {
                        $('.number-of-widget').remove();
                        showNotification()
                    });

                    if ($('#initonboard').length === 0 && jmemberData.HasStore && jmemberData.IsNew && jmemberData.StoreID === __appGullStoreId)
                        $('[aria-labelledby="rightMenu570"]').append(`<a id="initonboard" href="#initonboard" class="dropdown-item px-3"><i style="padding-left:28px"></i>Workspace Configuration</a>`)

                });



                if (jmemberData.RemoveTour) {

                    $(`head`).append(`<style id="tour-css">
#appcues-whs-elem{display: none !important}

</style>`);
                }


                if (jmemberData.RemoveSidebard) {


                    $(`head`).append(`<style id="teslstra-css">
[title="Click to view risk assessment record"], #sideContentWrap {display: none !important}
.main-content-wrap.sidenav-open {width: 100% !important}
#static-breadcrumbs {display: none !important}
</style>`);


                    $(`#sideContentWrap,
#ctl00_wcMainContentPlaceHolder_wcPageView5029_userControl_Button2,
#ctl00_wcMainContentPlaceHolder_wcPageView5029_userControl_dropdownPrint
,#ctl00_wcMainContentPlaceHolder_wcPageView5029_userControl_Button4,
#ctl00_wcMainContentPlaceHolder_wcPageView5029_userControl_action_frommasterlist,
#ctl00_wcMainContentPlaceHolder_wcPageView5029_userControl_action_copymove
`).remove();





                    $('.main-header a, .main-header .menu-toggle, .header-part-right').remove()
                }


            }


        });
        //   });
        var __sideBarIsLoaded = false;
        setTimeout(function () {
            if (!__sideBarIsLoaded)
                loadSideToggle();
        }, 1000)

        $(document).ready(function () {
            if ($(window).width() >= 768 && $(window).width() <= 1024) {

                var scrollTimer; // holds the timeout

                $(window).on('scroll', function () {
                    // Remove class while scrolling
                    $('.sidebar-left').addClass('d-none');
                    $('.sidebar-left').removeClass('open');
                    // Clear any previous timer
                    clearTimeout(scrollTimer);

                    // Set a new timer to add class back after 200ms of no scroll
                    scrollTimer = setTimeout(function () {
                        $('.sidebar-left').removeClass('open');
                        $('.sidebar-left').removeClass('d-none');
                    }, 200);
                });

            }
        });

        function loadSideToggle() {

            $('input').attr('autocomplete', 'off');
            $sidebarToggle = $(".menu-toggle");
            $sidebarLeft = $(".sidebar-left");
            $sidebarLeftSecondary = $(".sidebar-left-secondary");
            $sidebarOverlay = $(".sidebar-overlay");
            $mainContentWrap = $(".main-content-wrap");
            $sideNavItem = $(".nav-item");

            function openSidebar() {
                $sidebarLeft.addClass("open");
                $mainContentWrap.addClass("sidenav-open");
            }

            function closeSidebar() {
                $sidebarLeft.removeClass("open");
                $mainContentWrap.removeClass("sidenav-open");
            }

            function openSidebarSecondary() {
                $sidebarLeftSecondary.addClass("open");
                $sidebarOverlay.addClass("open");
            }

            function closeSidebarSecondary() {
                $sidebarLeftSecondary.removeClass("open");
                $sidebarOverlay.removeClass("open");
            }

            function openSidebarOverlay() {
                $sidebarOverlay.addClass("open");
            }

            function closeSidebarOverlay() {
                $sidebarOverlay.removeClass("open");
            }

            function navItemToggleActive($activeItem) {
                var $navItem = $(".nav-item");
                $navItem.removeClass("active");
                $activeItem.addClass("active");
            }

            function initLayout() {
                // Makes secondary menu selected on page load
                $sideNavItem.each(function (index) {
                    var $item = $(this);
                    if ($item.hasClass("active")) {
                        var dataItem = $item.data("item");
                        $sidebarLeftSecondary.find("[data-parent=\"" + dataItem + "\"]").show();
                    }
                });
                if (gullUtils && gullUtils.isMobile()) {
                    closeSidebar();
                    closeSidebarSecondary();
                }
            }

            $(window).on("resize", function (event) {
                if (gullUtils && gullUtils.isMobile()) {
                    closeSidebar();
                    closeSidebarSecondary();
                }
            });

            // Show Secondary menu area on hover on side menu item;
            $sidebarLeft.find(".nav-item").on("mouseenter", function (event) {
                var $navItem = $(event.currentTarget);
                var dataItem = $navItem.data("item");
                var dataPanel = $navItem.data("panel");

                if (dataPanel) {
                    navItemToggleActive($navItem);
                    closeSidebarSecondary();
                } else if (dataItem) {
                    navItemToggleActive($navItem);
                    openSidebarSecondary();
                } else {
                    closeSidebarSecondary();
                }
                $sidebarLeftSecondary.find(".childNav").hide();
                $sidebarLeftSecondary.find("[data-parent=\"" + dataItem + "\"]").show();
            });
            // Prevent opeing link if has data-item
            $sidebarLeft.find(".nav-item").on("click", function (e) {
                var $navItem = $(event.currentTarget);
                var dataItem = $navItem.data("item");
                if (dataItem) {
                    e.preventDefault();
                }
            });
            // Hide secondary menu on click on overlay
            $sidebarOverlay.on("click", function (event) {
                if (gullUtils.isMobile()) {
                    closeSidebar();
                }
                closeSidebarSecondary();
            });
            if ($('body').width() < 1300)
                closeSidebar();
            // Toggle menus on click on header toggle icon
            $sidebarToggle.on("click", function (event) {
                var isSidebarOpen = $sidebarLeft.hasClass("open");
                var isSidebarSecOpen = $sidebarLeftSecondary.hasClass("open");
                var dataItem = $(".nav-item.active").data("item");

                if (isSidebarOpen && isSidebarSecOpen && gullUtils.isMobile()) {
                    closeSidebar();
                    closeSidebarSecondary();
                } else if (isSidebarOpen && isSidebarSecOpen) {
                    closeSidebarSecondary();
                } else if (isSidebarOpen) {
                    closeSidebar();
                } else if (!isSidebarOpen && !isSidebarSecOpen && !dataItem) {
                    openSidebar();
                } else if (!isSidebarOpen && !isSidebarSecOpen) {
                    openSidebar();
                    openSidebarSecondary();
                }
            });


            $('.main-content-wrap').hover(function () {
                closeSidebarSecondary();
            });

        }
        var renewingTime = 0;
        var isWarningDisplayed = false;
        var interval;
        var idleInterval;
        var idleTime = 0;
        var timerInterval;

        $(document).ready(function () {
            $('input').attr('autocomplete', 'off');
            setTimeout(function () {
                continueSession();
                interval = setInterval(activeSessionChecking, 1000);
                idleInterval = setInterval(timeIncrement, 1000);
            }, 120000);
            $('body').addClass('modern-theme');
			
			
        });

        $(document).bind("mousemove keypress", function () {
            setTimeout(function () {
                continueSession();
            }, 120000);
        });

        var expired = false;
        var pc = false;
        function timeIncrement() { idleTime = idleTime + 1; if (idleTime == 10) { $.post("<%=GetExtendCookieTimeoutService() %>"); } }

        function isRenewingTime() { var d = new Date(); if (parseInt(d.getTime()) >= parseInt(renewingTime)) { return true; } return false; }

        function activeSessionChecking() { if (isRenewingTime()) { getSession(); } }

        function continueSession() {
            idleTime = 0;
            var d = new Date();
            if (pc === true) {
                pc = false;
                if (isRenewingTime()) {
                    $.post("<%=GetExtendCookieTimeoutService() %>", function (data) {
                        getSession();
                        pc = true;
                    });
                }
            }

        }

        function renewSession() {


            $.post("<%=GetExtendCookieTimeoutService() %>", function (data) {
                countDown();
                var wcNotification = $find("<%= wcNotif.ClientID %>");
                wcNotification.hide();
                pc = true;
            });

        }

        function getSession() {
            var d = new Date();
            if (!expired) {
                $.post("<%=GetRemainingCookeTimeoutService() %> ", function (data) {
                    if (data.Expired) {
                        clearInterval(timerInterval);
                        clearInterval(interval);
                        clearInterval(idleInterval);
                        expired = true;
                        document.location.href = data.RedirectUri;
                        return;
                    }
                    renewingTime = data.RenewingTime.replace(/\D/g, "");
                    sessionTimeout = data.SessionTimeOutInSeconds;
                    if (!data.Expired && sessionTimeout > 0 && sessionTimeout <= 60) {
                        isWarningDisplayed = true;
                        clearInterval(interval);
                        clearInterval(idleInterval);
                        idleTime = 0;
                        interval = setInterval(countDown, 1000);
                        var wcNotification = $find("<%= wcNotif.ClientID %>");
                        wcNotification.show();
                        timerInterval = setInterval(function () { timer(sessionTimeout) }, 1000);
                        $(document).unbind("mousemove keypress");
                    }
                });
            }
        }

        function countDown() {
            var d = new Date();
            if (!expired) {
                $.post("<%=GetRemainingCookeTimeoutService() %> ", function (data) {
                    sessionTimeout = data.SessionTimeOutInSeconds;
                    if (data.Expired) {
                        clearInterval(timerInterval);
                        clearInterval(interval);
                        clearInterval(idleInterval);
                        expired = true;
                        document.location.href = data.RedirectUri;
                        return;
                    } else if (!data.Expired && sessionTimeout > 60) {
                        isWarningDisplayed = false;
                        var wcNotification = $find("<%= wcNotif.ClientID %>");
                        wcNotification.hide();
                        clearInterval(interval);
                        interval = setInterval(activeSessionChecking, 1000);
                        interval = setInterval(timeIncrement, 1000);
                        $(document).bind("mousemove keypress", function () {
                            continueSession();
                        });
                        clearInterval(timerInterval);
                    }
                });
            }
        }

        function timer(seconds) {
            var ctr = seconds;
            if (ctr > 60) {
                ctr = 60;
            }
            if (ctr > 0) {
                ctr = ctr - 1;
                $("#timeLbl").html(ctr);
            }
        }

        var isdmc = "<%=GetMemberIsDemo()%>";
        var hlpwdid = "<%=wcHelpRadWindow.ClientID %>"; var helpfolder = "<%=GetHelpLinkFolder()%>";

        function showmainhelp() { var owd = $find(hlpwdid); if (owd) { owd.setUrl('../../../' + helpfolder + '/index.html'); owd.show(); owd.center(); } }

        function redirecturl(surl) { window.location = surl; }

        function gotoSetupLoc() { window.location = '../../../App/Common/SetLocation.aspx'; }

