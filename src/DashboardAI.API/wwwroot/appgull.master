	 <style>
        .countdown {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0, 0, 0, 0.8);
            color: white;
            padding: 15px 25px;
            border-radius: 8px;
            display: none;
            font-family: Arial, sans-serif;
            min-width: 200px;
            text-align: center;
            z-index: 9999;
        }

        .timer-seconds {
            color: #ff4444;
            font-weight: bold;
        }

        .countdown.show {
            display: block;
            animation: fadeIn 0.3s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .warning {
            color: #ff4444;
        }

        .countdown-buttons {
            margin-top: 10px;
            display: none;
        }

        .countdown-buttons.show {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
        }

        .countdown-buttons button {
            padding: 8px 15px;
            margin-left: 10px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }

        .extend-btn {
            background: #4CAF50;
            color: white;
        }

        .logout-btn {
            background: #f44336;
            color: white;
        }

            .timer-seconds {
                color: #ff4444;
                font-weight: bold;
            }
        </style>


    <%--<script type="text/javascript">
        if ('<%=Agtech.Web.UI.Utility.IsDevelopment%>' === 'False') {
            var $zoho = $zoho || {}; $zoho.salesiq = $zoho.salesiq || { widgetcode:"<%=GetZohoBot()%>", values: {}, ready: function () { } }; var d = document; s = d.createElement("script"); s.type = "text/javascript"; s.id = "zsiqscript"; s.defer = true; s.src = "https://salesiq.zoho.com/widget"; t = d.getElementsByTagName("script")[0]; t.parentNode.insertBefore(s, t); d.write("<div id='zsiqwidget'></div>");
        }
    </script>--%>
	
	<script>

        function loadDashboardAI(url) {
            manualRightModal('#generate-dashboard-ai');
            $('#genrate-dashboard-ai iframe').attr('src', url)
        }

        // === Dynamic Checklist Dashboard (Master Page drop-in; jQuery-only) ===
        // Adds/updates one loader per (HazardTemplateID + dashboardName).
        // Keeps COMPLETED items visible and shows the date completed.

        (function (w) {
            var API_URL = '../../NetServices/PostDynamicChecklist.asmx/sp_DDQ_SummaryByStoreTemplate';
            var CONTAINER_ID = 'sync-dashboard';
            var TITLE_TEXT = 'Dynamic Data Sync';
            var POLL_MS_ACTIVE = 10000;
            var POLL_MS_IDLE = 6000;
            var syncDashboardLoadedAt = Date.now();
            var syncDashboardDismissed = {}; // key: dashboardKey, value: lastDismissedTime (ms)

            function withJQ(cb) {
                if (w.jQuery) return cb(w.jQuery);
                var s = document.createElement('script');
                s.src = 'https://code.jquery.com/jquery-3.7.1.min.js';
                s.onload = function () { cb(w.jQuery); };
                document.head.appendChild(s);
            }

            function getInitials(name) {
                if (!name) return '';
                var parts = name.trim().split(/\s+/);
                if (parts.length === 1) return parts[0][0] ? parts[0][0].toUpperCase() : '';
                return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
            }

            function renderSyncDashboard() {
                withJQ(function ($) {
                    // Store previous percentComplete for each record
                    if (!window.__syncPrevStatus) window.__syncPrevStatus = {};
                    var prevStatus = window.__syncPrevStatus;

                    function poll() {
                        $.ajax({
                            url: API_URL,
                            type: 'POST',
                            contentType: 'application/json; charset=utf-8',
                            dataType: 'json',
                            data: '{}',
                            success: function (resp) {
                                $('#alert-container .grid').remove();
                                var rows = resp && resp.d ? resp.d : resp;
                                if (typeof rows === 'string') {
                                    try { rows = JSON.parse(rows); } catch { rows = []; }
                                }
                                if (!Array.isArray(rows) && rows && typeof rows === 'object') {
                                    for (var k in rows) { if (Array.isArray(rows[k])) { rows = rows[k]; break; } }
                                }
                                if (!Array.isArray(rows)) rows = [];

                                var $wrap = $('#' + CONTAINER_ID);
                                if ($wrap.length === 0) $wrap = $('<div/>', { id: CONTAINER_ID }).appendTo('body');
                                $wrap.empty();

                                var $container = $('#alert-container');
                                var $grid = $('<div class="grid"></div>').prependTo($container);

                                rows.forEach(function (row) {
                                    var recordId = row.RegID || row.HazardTemplateID || Math.floor(Math.random() * 1000000);
                                    var dateOrder = row.dateorder || (row.lastFinished || row.lastfinished || row.LastFinished || row.Lastfinished || '');
                                    var link = row.dashboardUrl || row.RegUrl || '#';
                                    var title = row.dashboardName || row.RegTitle || 'Incident Assessor';
                                    var description = row.RegDescription || row.Description || '';
                                    var badgeName = (row.jmemberData && row.jmemberData.FirstName && row.jmemberData.Surname)
                                        ? (row.jmemberData.FirstName + ' ' + row.jmemberData.Surname)
                                        : 'User';
                                    var initials = getInitials(badgeName);

                                    function parseDotNetDate(str) {
                                        var m = /\/Date\((\d+)\)\//.exec(str);
                                        if (m) return new Date(+m[1]);
                                        var d = new Date(str);
                                        return isNaN(d) ? null : d;
                                    }
                                    var finishedDate = parseDotNetDate(row.lastFinished);

                                    function formatDateSmart(d) {
                                        if (!d) return '-';
                                        var now = new Date();
                                        if (
                                            d.getFullYear() === now.getFullYear() &&
                                            d.getMonth() === now.getMonth() &&
                                            d.getDate() === now.getDate()
                                        ) {
                                            var hours = d.getHours();
                                            var mins = d.getMinutes();
                                            var ampm = hours >= 12 ? 'PM' : 'AM';
                                            var displayHour = hours % 12;
                                            if (displayHour === 0) displayHour = 12;
                                            var minsStr = mins < 10 ? '0' + mins : mins;
                                            return `Today ${displayHour}:${minsStr} ${ampm}`;
                                        }
                                        return d.toLocaleString();
                                    }
                                    var dateStr = finishedDate ? formatDateSmart(finishedDate) : '-';

                                    var statusText = (+row.percentComplete === 100) ? 'Done' : 'In progress';
                                    var statusBadge = (statusText === 'Done')
                                        ? `<span class="badge" style="background-color:#c1efdf;color:#00B050 !important;font-size:9px;margin-right:8px;">${statusText}</span>`
                                        : `<span class="badge" style="background-color:#F1f4ff !important;color:#007bff !important;font-size:9px;margin-right:8px;">${statusText}</span>`;
                                    var detailsText = `Syncing checklist data. ${statusBadge}<br/><span style="color:#888">${dateStr}</span>`;

                                    var $card = $(`
<div id="record-id-${recordId}" dateorder="${dateOrder}" onclick="alertRecordLink('${link}')" style="border-bottom: 1px solid rgba(0, 0, 0, 0.03) !important" class="p-2 alert-item">
  <div class="mb-1">
    <span style="font-size: 85%; color:#007bff!important;">
      <span style="font-size:18px;top: 3px;position: relative;" class="linear-cloud-sync mr-1"></span>
      <span class="mr-1">${title} Dashboard</span>
    </span>
  </div>
  <div class="d-flex justify-content-between pl-1">
    <div style="max-width:300px; font-size: 11px">
      <div class="small">${description}</div>
      <div class="small">${detailsText}</div>
    </div>
    <div style="position:relative">
      <div style="position: absolute; bottom: 5px; right: 5px;" class="d-flex justify-content-end">
        <div id="worker-${recordId}" style="width:25px; height:25px">
          <div title="${badgeName}" style="max-width:26px;max-height:29px;border-radius:50%;padding: 5px 1px 5px 1px;text-align: center;font-size:10px" class="bg-primary font-weight-bold text-white">${initials}</div>
        </div>
      </div>
    </div>
  </div>
</div>
`);
                                    $grid.append($card);

                                    // --- Floating notification for completed syncs ---
                                    var key = row.HazardTemplateID || row.RegID || ''; // Use HazardTemplateID if available
                                    var nowVal = +row.percentComplete;

                                    // Parse finishedDate
                                    var finishedDate = null;
                                    if (row.lastFinished) {
                                        var m = /\/Date\((\d+)\)\//.exec(row.lastFinished);
                                        if (m) finishedDate = new Date(+m[1]);
                                        else {
                                            var d = new Date(row.lastFinished);
                                            if (!isNaN(d)) finishedDate = d;
                                        }
                                    }

                                    var lastDismissed = syncDashboardDismissed[key] || 0;

                                    // Show toaster for all 100% records, but only if not dismissed and not already shown
                                    if (
                                        nowVal === 100 &&
                                        finishedDate &&
                                        finishedDate.getTime() > lastDismissed &&
                                        key && // Only if key exists
                                        !document.getElementById('sync-float-completed-' + key)
                                    ) {
                                        showSyncCompleted(
                                            row.dashboardName || row.RegTitle || 'Record',
                                            row.dashboardUrl || row.RegUrl || '#',
                                            key,
                                            finishedDate.getTime(),
                                            row.dashboardID
                                        );
                                    }
                                    prevStatus[key] = nowVal;
                                });

                                function showSyncCompleted(title, url, dashboardKey, finishedTime, dashboardID) {
                                    bulkDeleteDashboardCache(dashboardID)
                                    var floatId = 'sync-float-completed-' + dashboardKey;
                                    if (document.getElementById(floatId)) return;

                                    var el = document.createElement('div');
                                    el.id = floatId;
                                    el.style.cssText = 'position:fixed;right:24px;z-index:9999;max-width:320px;top:100px;';
                                    document.body.appendChild(el);

                                    var html = `
    <div class="alert alert-success" style="box-shadow:0 2px 8px rgba(0,0,0,0.15);border-radius:8px;margin-bottom:10px;display:flex;align-items:center;position:relative;cursor:pointer;"
      onclick="(function(){
        var d=window.syncDashboardDismissed||{};
        d['${dashboardKey}']={finishedTime:${finishedTime},ts:Date.now()};
        localStorage.setItem('syncDashboardDismissed',JSON.stringify(d));
        if(window.deleteSyncDashboard) window.deleteSyncDashboard('${dashboardKey}');
        setTimeout(function(){ window.location.href='${url}'; }, 200);
      })()">
      <span class="linear-cloud-sync mr-2" style="font-size:22px;color:#00B050"></span>
      <div>
	   
        <div style="font-weight:600;color:#00B050;" class="mb-0">
		Sync completed</div>
        <div style="font-size:13px;color:#333;">${title} is now 100% synced.</div>
      </div>
      <button type="button" style="position:absolute;top:6px;right:8px;background:none;border:none;font-size:18px;line-height:1;color:#888;cursor:pointer;"
        onclick="event.stopPropagation();(function(){
          var d=window.syncDashboardDismissed||{};
          d['${dashboardKey}']={finishedTime:${finishedTime},ts:Date.now()};
          localStorage.setItem('syncDashboardDismissed',JSON.stringify(d));
          if(window.deleteSyncDashboard) window.deleteSyncDashboard('${dashboardKey}');
          (function(btn){var el=btn;while(el&&(!el.classList||!el.classList.contains('alert')))el=el.parentNode;if(el&&el.parentNode)el.parentNode.removeChild(el);})(this);
        })()">×</button>
    </div>
  `;
                                    el.innerHTML = html;
                                    setTimeout(function () {
                                        if (el && el.parentNode) el.parentNode.removeChild(el);
                                    }, 30 * 60 * 1000);
                                }

                                // Poll again after delay
                                setTimeout(poll, POLL_MS_ACTIVE);
                            },
                            error: function (xhr, status) {
                                setTimeout(poll, POLL_MS_IDLE);
                            }
                        });
                    }

                    poll();
                });
            }

            // Expose as callable function
            w.renderSyncDashboard = renderSyncDashboard;

            // Example alert function (replace with your own logic)
            w.alertRecordLink = function (url) {
                //document.location.href = ''
                window.location.href = url; // Uncomment to actually navigate
            };

            function renderStaticSyncDashboard(rows) {

                withJQ(function ($) {
                    var $container = $('#alert-container');
                    $container.empty();
                    var $grid = $('<div class="grid"></div>').prependTo($container);

                    rows.forEach(function (row) {
                        var recordId = row.RegID || row.HazardTemplateID || Math.floor(Math.random() * 1000000);
                        var dateOrder = row.dateorder || (row.lastFinished || row.lastfinished || row.LastFinished || row.Lastfinished || '');
                        var link = row.dashboardUrl || row.RegUrl || '#';
                        var title = row.dashboardName || row.RegTitle || 'Incident Assessor';
                        var description = row.RegDescription || row.Description || '';
                        var badgeName = (jmemberData && jmemberData.FirstName && jmemberData.Surname)
                            ? (jmemberData.FirstName + ' ' + jmemberData.Surname)
                            : 'User';
                        var initials = getInitials(badgeName);

                        function parseDotNetDate(str) {
                            var m = /\/Date\((\d+)\)\//.exec(str);
                            if (m) return new Date(+m[1]);
                            var d = new Date(str);
                            return isNaN(d) ? null : d;
                        }
                        var finishedDate = parseDotNetDate(row.lastFinished);

                        function formatDateSmart(d) {
                            if (!d) return '-';
                            var now = new Date();
                            if (
                                d.getFullYear() === now.getFullYear() &&
                                d.getMonth() === now.getMonth() &&
                                d.getDate() === now.getDate()
                            ) {
                                var hours = d.getHours();
                                var mins = d.getMinutes();
                                var ampm = hours >= 12 ? 'PM' : 'AM';
                                var displayHour = hours % 12;
                                if (displayHour === 0) displayHour = 12;
                                var minsStr = mins < 10 ? '0' + mins : mins;
                                return `Today ${displayHour}:${minsStr} ${ampm}`;
                            }
                            return d.toLocaleString();
                        }
                        var dateStr = finishedDate ? formatDateSmart(finishedDate) : '-';

                        var statusText = (+row.percentComplete === 100) ? 'Done' : 'In progress';
                        var statusBadge = (statusText === 'Done')
                            ? `<span class="badge" style="background-color:#c1efdf;color:#00B050 !important;font-size:9px;margin-right:8px;">${statusText}</span>`
                            : `<span class="badge" style="background-color:#F1f4ff !important;color:#007bff !important;font-size:9px;margin-right:8px;">${statusText}</span>`;
                        var detailsText = `Syncing checklist data. ${statusBadge}<br/><span style="color:#888">${dateStr}</span>`;

                        var $card = $(`
<div id="record-id-${recordId}" dateorder="${dateOrder}" onclick="alertRecordLink('${link}')" style="border-bottom: 1px solid rgba(0, 0, 0, 0.03) !important" class="p-2 alert-item">
  <div class="mb-1">
    <span style="font-size: 85%; color:#007bff!important;">
      <span style="font-size:18px;top: 3px;position: relative;" class="linear-cloud-sync mr-1"></span>
      <span class="mr-1">${title} Dashboard</span>
    </span>
  </div>
  <div class="d-flex justify-content-between pl-1">
    <div style="max-width:300px; font-size: 11px">
      <div class="small">${description}</div>
      <div class="small">${detailsText}</div>
    </div>
    <div style="position:relative">
      <div style="position: absolute; bottom: 5px; right: 5px;" class="d-flex justify-content-end">
        <div id="worker-${recordId}" style="width:25px; height:25px">
          <div title="${badgeName}" style="max-width:26px;max-height:29px;border-radius:50%;padding: 5px 1px 5px 1px;text-align: center;font-size:10px" class="bg-primary font-weight-bold text-white">${initials}</div>
        </div>
      </div>
    </div>
  </div>
</div>
`);
                        $grid.append($card);
                    });
                });
            }

            // Expose as callable function
            w.renderStaticSyncDashboard = renderStaticSyncDashboard;

            function goBeforeDelete(id, url) {
                deleteSyncDashboard(id).done(function () {
                    document.location.href = url;
                })
            }
            w.goBeforeDelete = goBeforeDelete;
            function deleteSyncDashboard(id) {
                if (!id) return;
                // Broadcast to other tabs
                localStorage.setItem('removeSyncFloatCompleted', id);

                return $.ajax({
                    url: '../../NetServices/PostDynamicChecklist.asmx/sp_DDSQ_SummaryByStoreTemplateDelete',
                    type: 'POST',
                    contentType: 'application/json; charset=utf-8',
                    dataType: 'json',
                    data: JSON.stringify({ data: { ID: id } }),
                    success: function (resp) {
                        $(`#sync-float-completed-${id}`).remove();
                    },
                    error: function (xhr, status) {
                        // Optionally handle error
                    }
                }).done(function () {
                    $(`#sync-float-completed-${id}`).remove();
                });
            }
            w.deleteSyncDashboard = deleteSyncDashboard;
        })(window);

        renderSyncDashboard();
        function bulkDeleteDashboardCache(dashboardID) {

            const uid = (window.jmemberData && window.jmemberData.MemberID)
                ? window.jmemberData.MemberID
                : "global";
            const prefix = `limitAjaxCache:${uid}:`;
            for (let i = localStorage.length - 1; i >= 0; i--) {
                const key = localStorage.key(i);
                if (key && key.startsWith(prefix) && key.endsWith(':' + dashboardID)) {
                    localStorage.removeItem(key);
                }
            }
        }

        window.addEventListener('storage', function (e) {
            if (e.key === 'removeSyncFloatCompleted' && e.newValue) {
                $(`#sync-float-completed-${e.newValue}`).remove();
                // Optionally clear the key so it can be triggered again
                //localStorage.removeItem('removeSyncFloatCompleted');
            }
        });
		</script>
		
		
