        function getDataFromRadObject(data) {
            if (($find(data) == null || $find(data) == undefined) && ($get(data) == undefined || $get(data) == null)) {
                return '';
            }
            else {
                if (isRadComboBox($find(data)))
                    return $find(data).get_value();
                else
                    return $get(data).value;
            }
        }

        function isRadComboBox(obj) { return Telerik.Web.UI.RadComboBox.isInstanceOfType(obj) }

        function checkwdadaptive() {
            return Telerik.Web.BrowserFeatures.touchEvents && $telerik.$(window).width() < 768;
        }

        function onwdshow(sender, args) {

            if (checkwdadaptive()) {
                sender.set_behaviors(Telerik.Web.UI.WindowBehaviors.Close)
                sender.set_visibleStatusbar(false);
                sender.maximize();

            } else
                sender.setSize(900, 750);
        }

