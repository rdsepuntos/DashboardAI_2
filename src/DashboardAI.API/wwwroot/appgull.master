                <%-- Body Placeholder --%>
                <asp:ContentPlaceHolder ID="wcMainContentPlaceHolder" runat="server"></asp:ContentPlaceHolder>

                <%-- Body Spacer --%>
                <div class="pt-4"></div>

                <%-- RadNotification --%>
                <telerik:RadNotification ID="wcNotif" runat="server"
                    Style="z-index: 9999999"
                    Position="Center"
                    Width="320"
                    Height="100"
                    Title="Your session is about to expire.."
                    Skin="Simple"
                    EnableRoundedCorners="true"
                    ShowCloseButton="false"
                    KeepOnMouseOver="false"
                    ShowInterval="0"
                    TabIndex="1"
                    AutoCloseDelay="0">
                    <ContentTemplate>
                        Time remaining: <span id="timeLbl">60</span>
                        <br />
                        <telerik:RadButton Skin="Simple" ID="continueSession" runat="server" Text="Click here to  extend your session"
                            Style="margin-top: 10px;" AutoPostBack="false" OnClientClicked="renewSession">
                        </telerik:RadButton>
                    </ContentTemplate>
                </telerik:RadNotification>

                <%-- PANEL Intercom --%>
                <asp:Panel ID="wcIntercomPnl" runat="server" Visible="false">
                    <script type="text/javascript">
                        window.intercomSettings = {
                            app_id: "ubdbxnp9"
                            , "source_website": "WHS Monitor"
                            , "email": "<%=GetMemberEmail()%>"
                            , "user_id": "<%=GetMemberUserName()%>"
                            , "name": "<%=GetCurrentMemberName()%>"
                        };
                    </script>
                    <script type="text/javascript">
                        (function () {
                            var w = window;
                            var ic = w.Intercom;
                            if (typeof ic === "function") {
                                ic('reattach_activator');
                                ic('update', intercomSettings);
                            } else {
                                var d = document;
                                var i = function () {
                                    i.c(arguments)
                                };
                                i.q = [];
                                i.c = function (args) {
                                    i.q.push(args)
                                };
                                w.Intercom = i;
                                function l() {
                                    var s = d.createElement('script');
                                    s.type = 'text/javascript';
                                    s.async = true;
                                    s.src = 'https://widget.intercom.io/widget/ubdbxnp9';
                                    var x = d.getElementsByTagName('script')[0]; x.parentNode.insertBefore(s, x);
                                }
                                if (w.attachEvent) {
                                    w.attachEvent('onload', l);
                                } else {
                                    w.addEventListener('load', l, false);
                                }
                            }
                        })();
                    </script>
                </asp:Panel>

                <%-- RadWindow --%>
                <telerik:RadWindow ID="wcHelpRadWindow" runat="server"
                    Style="z-index: 12100"
                    KeepInScreenBounds="true"
                    Modal="true"
                    Width="820px"
                    Height="500px"
                    VisibleStatusbar="false">
                </telerik:RadWindow>
                <!--=============== End content place holder ================-->
