        <input id="wcTabClientSelectedIndicator" type="hidden" runat="server" />


        <!--=============== Confirm Subscriptions ================-->
        <div class="modal-side h-100 w-50 card top right position-fixed rounded-0 d-none" style="margin-right: -100%;" id="confirm-subscription">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <div class="h5 text-light">Start Full Subscription</div>
                <button id="confirm-subscription-close" type="button" class="close" data-dismiss="right-close-modal" aria-label="Close">
                    <span aria-hidden="true"><i class="icon-arventa linear-cross"></i></span>
                </button>
            </div>
            <div class="card-body modal-body show pt-1">
                <div class="px-2 h-100 mt-3">
                    <div class="mb-5">
                        <div class="form-group">
                            <span>By clicking <b>Confirm Subscription</b>, this will then finish the 30 day money back guarantee period of your license and proceed to the full subscription.
                            </span>
                        </div>
                        <div class="form-group mt-2">
                            <span>As part of proceeding to the full subscription, additional industry specific compliance templates will be automatically added to your account for your use at no additional charge.</span>
                        </div>
                        <div class="form-group mt-5">
                            <div class="classic-submenu mt-4 w-100" runat="server" id="Div4">
                                <div class="row">
                                    <div class="col-12">
                                        <button id="wcConfirmSub" type="button" onclick="CommitSubscriptionProceed(1); return false;" class="btn btn btn-themed w-100">Confirm Subscription</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--=============== End Confirm Subscriptions ================-->

        <!--=============== Commit Subscriptions ================-->
        <div class="modal-side h-100 w-50 card top right position-fixed rounded-0 d-none" style="margin-right: -100%;" id="commit-subscription">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <div class="h5 text-light">Start Full Subscription</div>
                <button id="commit-subscription-close" type="button" class="close" data-dismiss="right-close-modal" aria-label="Close">
                    <span aria-hidden="true"><i class="icon-arventa linear-cross"></i></span>
                </button>
            </div>
            <div class="card-body modal-body show pt-1">
                <div class="px-2 h-100 mt-3">
                    <div class="mb-5">
                        <div id="over30" class="d-none">Congratulations on completing the first 30 days of your license!</div>
                        <div id="under30" class="d-none">Congratulations on proceeding to the full subscription license!</div>
                        <p class="mt-3">Now that you have moved to the full subscription license, additional industry templates have been automatically populated in your account for use.</p>
                        <p class="mt-3">You can also now elect to remove any or all example records from the account from operational use.</p>
                    </div>
                    <div class="mt-5">
                        <div class="classic-submenu w-100" runat="server" id="wcSaveProject">
                            <div class="row">
                                <div class="col-12">
                                    <button type="button" id="wcDeleteAllBtn" onclick="Subscription('all')" class="btn btn btn-themed w-75" style="text-align: left !important;">>> Delete all Test Data</button>
                                </div>
                            </div>
                        </div>
                        <div class="classic-submenu mt-4 w-100" runat="server" id="Div1">
                            <div class="row">
                                <div class="col-12">
                                    <button type="button" id="wcDeleteByModuleBtn" onclick="showDeleteRecords(); return false;" class="btn btn btn-themed w-75" style="text-align: left !important;">>> Delete Test Data by Module</button>
                                </div>
                            </div>
                        </div>
                        <div class="classic-submenu mt-4 w-100" runat="server" id="Div2">
                            <div class="row">
                                <div class="col-12">
                                    <button type="button" id="wcProceed" onclick="Subscription('skip'); return false;" class="btn btn btn-themed w-75" style="text-align: left !important;">>> Skip</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div>
                        <p class="mt-5">Don't worry if you aren't ready to remove them yet, you can always do so from the <a href="../../App/Farm/AddEditFarm.aspx?Page=500&Store=<%=Agtech.Web.UI.Utility.GetCurrentStoreID() %>#RemoveTestData" target="_blank">Organisation Details</a> page.</p>
                        <p class="mt-3">Regards,</p>
                        <p>WHS Monitor Support Team</p>
                    </div>
                </div>
            </div>
        </div>
        <!--=============== End Commit Subscriptions ================-->

        <!--=============== Confirm Cancel Subscriptions ================-->
        <div class="modal-side h-100 w-50 card top right position-fixed rounded-0 d-none" style="margin-right: -100%;" id="confirm-cancel-subscription">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <div class="h5 text-light">Cancel Subscription</div>
                <button id="confirm-cancel-subscription-close" type="button" class="close" data-dismiss="right-close-modal" aria-label="Close">
                    <span aria-hidden="true"><i class="icon-arventa linear-cross"></i></span>
                </button>
            </div>
            <div class="card-body modal-body show pt-1">
                <div class="px-2 h-100 mt-5">
                    <div class="mb-5">
                        <div class="form-group">
                            <p>
                                By clicking <b>Cancel Subscription</b>, this action will cancel your license and you will no longer be able to access WHS Monitor or any of the data contained within.
                            </p>
                        </div>
                        <div class="form-group mt-2">
                            <p>
                                If you wish to continue using the system, click <b>Keep Subscription</b> or click away from this page to close it.
                            </p>
                        </div>

                        <div class="form-group mt-5">
                            <div class="classic-submenu mt-4 w-100" runat="server" id="Div5">
                                <div class="row">
                                    <div class="col-6">
                                        <button type="button" id="wcKeepSubs" onclick="closeAllRightModal(); return false;" class="btn btn btn-success w-100">Keep Subscription</button>
                                    </div>
                                    <div class="col-6">
                                        <asp:LinkButton ID="wcSubmitCancelFeedback" runat="server"
                                            CssClass="btn btn btn-outline-gray w-100"
                                            OnClick="wcSubmitCancelFeedback_Click"
                                            ValidationGroup="HeaderSignOut"
                                            CausesValidation="false">
                                                Cancel Subscription
                                        </asp:LinkButton>
                                    </div>
                                    <%--<div class="col-6">
                                        <button id="wcConfirmCancel" onclick="ConfirmCancelSubscription(); return false;" class="btn btn btn-danger w-100">Cancel My Subscription</button>
                                    </div>--%>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--=============== End Confirm Cancel Subscriptions ================-->

        <!--=============== Cancel Subscriptions ================-->
        <div class="modal-side h-100 w-50 card top right position-fixed rounded-0 d-none" style="margin-right: -100%;" id="cancel-subscription">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <div class="h5 text-light">Cancel Subscription</div>
                <%--                <button id="cancel-subscription-close" type="button" class="close" data-dismiss="right-close-modal" aria-label="Close">
                    <span aria-hidden="true"><i class="icon-arventa linear-cross"></i></span>
                </button>--%>
            </div>
            <div class="card-body modal-body show pt-1">
                <div class="px-2 h-100 mt-3">
                    <div class="mb-5">
                        <div class="form-group mt-3">
                            <p>
                                We're sorry to see you go!
                            </p>
                        </div>
                        <div class="form-group mt-4">

                            <p>Your experience matters to us so before you go let us know why you are cancelling subscription:</p>
                            <div class="mt-3">
                                <div class="mb-1">
                                    <asp:CheckBox runat="server" CausesValidation="false" ID="SrvQ" onchange="showSrvQTB(); return false;" Text="Service quality or performance" />
                                    <div id="dsrvq" runat="server" class="d-none">
                                        <telerik:RadTextBox ID="SrvQTB" runat="server"
                                            Skin="Bootstrap"
                                            WrapperCssClass="w-75"
                                            TextMode="MultiLine" Rows="3"
                                            CssClass="flex-grow-1 p-0 rounded border"
                                            InputCssClass="form-control form-control-sm">
                                        </telerik:RadTextBox><sup class="text-danger ml-1" style="top: -20px !important;"><small><i class="fa fa-asterisk"></i></small></sup>
                                    </div>
                                </div>
                                <div class="mb-1">
                                    <asp:CheckBox runat="server" CausesValidation="false" ID="DifU" onchange="showDifUTB(); return false;" Text="Difficult to use/understand" />
                                    <div id="ddifu" runat="server" class="d-none">
                                        <telerik:RadTextBox ID="DifUTB" runat="server"
                                            Skin="Bootstrap"
                                            WrapperCssClass="w-75"
                                            TextMode="MultiLine" Rows="3"
                                            CssClass="flex-grow-1 p-0 rounded border"
                                            InputCssClass="form-control form-control-sm">
                                        </telerik:RadTextBox><sup class="text-danger ml-1" style="top: -20px !important;"><small><i class="fa fa-asterisk"></i></small></sup>
                                    </div>
                                </div>
                                <div class="mb-1">
                                    <asp:CheckBox runat="server" CausesValidation="false" ID="NotL" onchange="showNotLTB(); return false;" Text="Not what I was looking for" />
                                    <div id="dnotl" runat="server" class="d-none">
                                        <telerik:RadTextBox ID="NotLTB" runat="server"
                                            Skin="Bootstrap"
                                            WrapperCssClass="w-75"
                                            TextMode="MultiLine" Rows="3"
                                            CssClass="flex-grow-1 p-0 rounded border"
                                            InputCssClass="form-control form-control-sm">
                                        </telerik:RadTextBox><sup class="text-danger ml-1" style="top: -20px !important;"><small><i class="fa fa-asterisk"></i></small></sup>
                                    </div>
                                </div>
                                <div class="mb-1">
                                    <asp:CheckBox runat="server" CausesValidation="false" ID="TExp" onchange="showTExpTB(); return false;" Text="Too expensive" />
                                    <div id="dtexp" runat="server" class="d-none">
                                        <telerik:RadTextBox ID="TExpTB" runat="server"
                                            Skin="Bootstrap"
                                            WrapperCssClass="w-75"
                                            TextMode="MultiLine" Rows="3"
                                            CssClass="flex-grow-1 p-0 rounded border"
                                            InputCssClass="form-control form-control-sm">
                                        </telerik:RadTextBox><sup class="text-danger ml-1" style="top: -20px !important;"><small><i class="fa fa-asterisk"></i></small></sup>
                                    </div>
                                </div>
                                <div class="mb-1">
                                    <asp:CheckBox runat="server" CausesValidation="false" ID="Othr" onchange="showOtherTB(); return false;" Text="Others(Please specify)" />
                                    <div id="dothr" runat="server" class="d-none">
                                        <telerik:RadTextBox ID="OthrTB" runat="server"
                                            Skin="Bootstrap"
                                            WrapperCssClass="w-75"
                                            TextMode="MultiLine" Rows="3"
                                            CssClass="flex-grow-1 p-0 rounded border"
                                            InputCssClass="form-control form-control-sm">
                                        </telerik:RadTextBox><sup class="text-danger ml-1" style="top: -20px !important;"><small><i class="fa fa-asterisk"></i></small></sup>
                                    </div>
                                </div>

                                <asp:CheckBoxList ID="wcFeedbackChk" runat="server" CssClass="frmTableNoBorder w-100 d-none" RepeatDirection="Vertical" RepeatLayout="Table" RepeatColumns="1">
                                </asp:CheckBoxList>
                            </div>
                        </div>
                        <div class="form-group mt-4 d-none">
                            <h5>Rate your overall satisfaction with our service:</h5>
                            <div class="mt-3">
                                <asp:RadioButtonList ID="wcRaitingRbl" runat="server" RepeatLayout="Flow">
                                    <asp:ListItem Value="5" Text="Very Satisfied"></asp:ListItem>
                                    <asp:ListItem Value="4" Text="Somewhat Satisfied"></asp:ListItem>
                                    <asp:ListItem Value="3" Text="Neutral"></asp:ListItem>
                                    <asp:ListItem Value="2" Text="Somewhat dissatisfied"></asp:ListItem>
                                    <asp:ListItem Value="1" Text="Very dissatisfied"></asp:ListItem>
                                </asp:RadioButtonList>
                            </div>
                        </div>
                        <div class="form-group mt-4 d-none">
                            <h5>Would you be open to a member of our team contacting you to discuss your experience further?</h5>
                            <div class="mt-3">
                                <asp:CheckBox ID="wcAllowContactChk" runat="server" Text="Yes" CssClass="checkbox-radio-m" />
                            </div>
                        </div>
                        <div class="form-group mt-3">
                            <span>Please tell us more about your reason cancelling. (<i class="font-grey">optional</i>)</span>
                            <div class="input-group w-100">
                                <div class="d-flex flex-grow-1">
                                    <telerik:RadTextBox ID="wcFeedbackCommentTb" runat="server"
                                        Skin="Bootstrap"
                                        WrapperCssClass="w-100"
                                        TextMode="MultiLine" Rows="5"
                                        CssClass="flex-grow-1 p-0 rounded border w-100"
                                        InputCssClass="form-control form-control-sm">
                                    </telerik:RadTextBox>
                                </div>
                            </div>
                        </div>
                        <div class="form-group mt-4" runat="server" id="Div3">
                            <div id="requireFeedback" class="mb-1 d-none">
                                <label><i>Please complete required fields marked with(<sup class="text-danger"><small><i class="fa fa-asterisk"></i></small></sup>)</i></label>
                            </div>
                            <div class="input-group w-100">
                                <button type="button" id="wcConfirmCancel" onclick="ConfirmCancelSubscription(); return false;" class="btn btn btn-themed w-100">Cancel Subscription</button>
                                <%-- <asp:LinkButton ID="wcSubmitCancelFeedback" runat="server"
                                        CssClass="btn btn btn-themed w-100"
                                        OnClick="wcSubmitCancelFeedback_Click"
                                        ValidationGroup="HeaderSignOut"
                                        CausesValidation="false">
                                                Cancel Subscription
                                    </asp:LinkButton>--%>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--=============== End Cancel Subscriptions ================-->
        <!-- DELETE RECORDS-->
        <div id="sample-records-modal" class="modal-side h-100 w-50 card top right position-fixed rounded-0" tabindex="-1" role="dialog" aria-labelledby="modal" aria-hidden="true">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <div class="h5 text-light">Delete Sample Records</div>
                <button id="sample-records-close" type="button" class="close" data-dismiss="right-close-modal" aria-label="Close">
                    <span aria-hidden="true"><i class="icon-arventa linear-cross"></i></span>
                </button>
