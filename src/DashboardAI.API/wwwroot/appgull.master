                    <asp:ContentPlaceHolder ID="BreadCrumb" Visible="true" runat="server"></asp:ContentPlaceHolder>
                </div>
                <div id="static-breadcrumbs" class="breadcrumbs-20 mb-2 d-none">
                    <div class="pb-2 border-bottom">
                        <span class="static-breadcrumbs-header h4 m-0 text-uppercase font-weight-bold">Header</span>
                        <span class="h4 m-0 pl-3 pr-2 d-none d-lg-inline-block">|</span>
                        <div class="d-lg-inline-block pt-2 p-lg-0 align-items-center">
                            <span><a href="/App/Main.aspx" class="text-black">Home</a></span>
                            <asp:ContentPlaceHolder ID="BreadCrumbStatic" Visible="true" runat="server"></asp:ContentPlaceHolder>
                        </div>
                        <div id="sync-wrapper" class="float-right d-none">
                            <button class="btn btn-outline-gray btn-sm bg-white btn-hover ml-1" type="button" id="btn-sync" onclick="spDynamicDataSync()">
                                <span class="d-flex align-items-center text-black">
                                    <span class="icon-arventa icon-arventa linear-sync top-0"></span>
                                    <span class="py-0-20-rem px-2">Sync</span>
